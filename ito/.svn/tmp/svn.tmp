#Context 설정server:  port: 8088  servlet:    context-path: /ito#스프링 설정
spring:  servlet:    multipart:      max-file-size: 20MB      max-request-size: 20MB      enabled: true
  http:    encoding:
      charset: UTF-8  #인코딩
  devtools:
    restart:
      enabled: false
    livereload:
      enabled: true
  #프로파일
  profiles:    active: local     #local: 로컬, dev: 개발서버, prod: 운영서버
    
  #thymeleaf(뷰) 설정
  thymeleaf:    view-names: thymeleaf/*       #뷰명이 thymeleaf로 시작하는것
    suffix: .html                 #확장자
    prefix: classpath:templates/ #뷰 파일 위치
    check-template-location: true #브라우저에 수정사항 반영
    cache: false                  #브라우저에 수정사항 반영(운영: true)
  #토큰인증
  auth:
    login: /api/token,POST
    authority: ROLE_USER
    jwt:
      ttl: 1h
      
#로그설정
logging:
  level:
    root: info

#암호화(jasypt)
jasypt:
  encryptor:
    bean: jasyptStringEncrptor

