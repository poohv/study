/*************************** FONTS CSS  ***************************/
/* noto-sans-kr-regular - latin */
@font-face {
    font-family: 'Noto Sans KR';
    font-style: normal;
    font-weight: 400;
    src: local('Noto Sans KR Regular'), local('NotoSansKR-Regular'),
        url('../fonts/noto-sans-kr-v12-latin-regular.woff2') format('woff2'),
        url('../fonts/noto-sans-kr-v12-latin-regular.woff') format('woff');
}
/* noto-sans-kr-500 - latin */
@font-face {
    font-family: 'Noto Sans KR';
    font-style: normal;
    font-weight: 500;
    src: local('Noto Sans KR Medium'), local('NotoSansKR-Medium'),
        url('../fonts/noto-sans-kr-v12-latin-500.woff2') format('woff2'),
        url('../fonts/noto-sans-kr-v12-latin-500.woff') format('woff');
}
/* noto-sans-kr-900 - latin */
@font-face {
    font-family: 'Noto Sans KR';
    font-style: normal;
    font-weight: 900;
    src: local('Noto Sans KR Black'), local('NotoSansKR-Black'),
        url('../fonts/noto-sans-kr-v12-latin-900.woff2') format('woff2'),
        url('../fonts/noto-sans-kr-v12-latin-900.woff') format('woff');
}
/* noto-sans-kr-700 - latin */
@font-face {
    font-family: 'Noto Sans KR';
    font-style: normal;
    font-weight: 700;
    src: local('Noto Sans KR Bold'), local('NotoSansKR-Bold'),
        url('../fonts/noto-sans-kr-v12-latin-700.woff2') format('woff2'),
        url('../fonts/noto-sans-kr-v12-latin-700.woff') format('woff');
}
/* open-sans-regular - latin */
@font-face {
    font-family: 'Open Sans';
    font-style: normal;
    font-weight: 400;
    src: local('Open Sans Regular'), local('OpenSans-Regular'),
        url('../fonts/open-sans-v17-latin-regular.woff2') format('woff2'),
        url('../fonts/open-sans-v17-latin-regular.woff') format('woff');
}
/* open-sans-600 - latin */
@font-face {
    font-family: 'Open Sans';
    font-style: normal;
    font-weight: 600;
    src: local('Open Sans SemiBold'), local('OpenSans-SemiBold'),
        url('../fonts/open-sans-v17-latin-600.woff2') format('woff2'),
        url('../fonts/open-sans-v17-latin-600.woff') format('woff');
}
/* open-sans-700 - latin */
@font-face {
    font-family: 'Open Sans';
    font-style: normal;
    font-weight: 700;
    src: local('Open Sans Bold'), local('OpenSans-Bold'),
        url('../fonts/open-sans-v17-latin-700.woff2') format('woff2'),
        url('../fonts/open-sans-v17-latin-700.woff') format('woff');
}
/* open-sans-800 - latin */
@font-face {
    font-family: 'Open Sans';
    font-style: normal;
    font-weight: 800;
    src: local('Open Sans ExtraBold'), local('OpenSans-ExtraBold'),
        url('../fonts/open-sans-v17-latin-800.woff2') format('woff2'),
        url('../fonts/open-sans-v17-latin-800.woff') format('woff');
}

/*************************** Common CSS  ***************************/
body,html{width:100%; height:100%; margin:0; padding:0; font-family:'Noto Sans KR', 'Open Sans', sans-serif; letter-spacing:-0.5px; font-size:14px; line-height:1.5; color:#626366; -webkit-print-color-adjust:exact; background-color:#ffffff; overflow:hidden;}
*{-webkit-text-size-adjust:none; -webkit-box-sizing:border-box; -moz-box-sizing:border-box; box-sizing:border-box;}
body,div,img,h1,h2,h3,h4,h5,h6,ul,ol,li,dl,dt,dd,p,span,form,fieldset,legend,input,table,tr,th,td{margin:0; padding:0; border:0; vertical-align:baseline; background:no-scroll transparent; direction:ltr;}
ul,ol,li{list-style-type:none;}
h1,h2,h3,h4,h5,h6{font-family:'Noto Sans KR', 'Open Sans', sans-serif; letter-spacing:-0.5px; font-weight:400; line-height:1.2;}
h1{font-size:25px !important; font-family:'Open Sans', sans-serif; color:#ffffff; font-weight:500;}
h2{font-size:30px !important; color:#003473; font-weight:600;}
h3{font-size:30px !important; color:#262626; padding-top:25px; font-weight:500;}
h4{font-size:15px;}
h5{font-size:14px;}
h6{font-size:13px;}
strong{font-weight:700;}
.mlf25{margin-left:25px;}
.mrt15{margin-right:15px;}
.mt45{margin-top:45px;}
.mt65{margin-top:65px;}
.plf35{padding-left:35px;}
.prt35{padding-right:35px;}

/* *************************** IoT Service Potal css *************************** */

/* *** header *** */
.headerWrap {
    width: 100%;
    height: 65px;
    background-color: #002A5E;
}

.headerWrap .container {
    max-width: 1680px;
    height: 100%;
    margin: 0 auto;
}

.Ulrow {
    text-align: center;
    clear: both;
}

.Licolumn {
    float: left;
    width: 100%;
    height: 65px;
    min-height: 65px;
    line-height: 65px;
}

.Licolumn.left {
    width: 50%;
    text-align: left;
    display: inline-block;
    vertical-align: middle;
    display: flex;
    align-items: center;
}

.Licolumn.right {
    width: 50%;
    text-align: right;
    display: inline-block;
}

.Ulrow .img {
    vertical-align: middle;
    display: inline;
}

/* *** section *** */
.section {
    width: 100%;
    height: 100%;
}

.section .sectionWrap {
    max-width: 1680px;
    height: calc(100% - 65px);
    margin: 0 auto;
}

.SWrap {
    text-align: center;
    clear: both;
    margin: auto 0;
    vertical-align: middle;
    height: 100%;

}

.Scol {
    float: left;
    width: 33.33%;
    padding: 0 50px;
    height: 100%;
    display: block;
    display: flex;
    align-items: center;
}

.Srow {
    text-align: center;
    clear: both;
}

.Scolumn {
    float: left;
    width: 100%;
}

.BoxWrap {
    font-size: 30px !important;
    color: #262626;
    font-weight: 500;
    width: 380px;
    height: 320px;
    background-color: #ffffff;
    border: 1px solid #4164D8 ;
    border-bottom: 15px solid #4164D8;
     border-radius: 10px;
    display: inline-block;
    vertical-align: middle;
}

.BoxWrap:hover {
    background-color: #4164D8;
    -webkit-transition-duration: 0.3s;
    transition-duration: 0.3s;
    color: #ffffff;
}

.BoxWrap .BoxInner P {
    padding-top: 25px;
}

.BoxWrap .BoxInner P em {
    font-style: normal;
    font-weight: 600;
    font-size: 28px;
    letter-spacing: -0.8px;
}

.BoxWrap .BoxInner {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    height: calc(320px - 15px);
}

.center {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 200px;
    border: 3px solid green;
}

/* *************************** Hover Event CSS *************************** */
/* *** Icon Grow *** */
.hvr-icon-grow {
    display: inline-block;
    vertical-align: middle;
    -webkit-transform: perspective(1px) translateZ(0);
    transform: perspective(1px) translateZ(0);
    box-shadow: 0 0 1px rgba(0, 0, 0, 0);
    -webkit-transition-duration: 0s;
    transition-duration: 0s;
}

.hvr-icon-grow .hvr-icon {
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-transition-duration: 0s;
    transition-duration: 0s;
    -webkit-transition-property: transform;
    transition-property: transform;
    -webkit-transition-timing-function: ease-out;
    transition-timing-function: ease-out;
}

.hvr-icon-grow:hover .hvr-icon,
.hvr-icon-grow:focus .hvr-icon,
.hvr-icon-grow:active .hvr-icon {
    -webkit-transform: scale(1.1) translateZ(0);
    transform: scale(1.1) translateZ(0);
}

.easyui-tabs .tabs-panels {
	border: none !important;
}

.easyui-tabs .tabs-header {
	border-style: none;
	border-bottom-style: solid;
}

.select2 .selection .is-invalid {
	border-color: #dc3545 !important;
}

.form-horizontal .input-group-append {
	display: inline;
}

.dataTable thead th, .dataTable thead td,
.dataTable tfoot th, .dataTable tfoot td {
	text-align: center !important;
	padding-right: 0 !important;
	padding-left: 0 !important;
}

.table .ui-sortable-helper {
	display: table;
}