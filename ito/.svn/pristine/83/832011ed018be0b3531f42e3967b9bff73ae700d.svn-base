<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.sr.SrGroupMapper">
	<sql id="search_query">
		SELECT *
		FROM (
			SELECT A.PERSONGROUP
				, B.PERSONID 
				, B.DISPLAYNAME 
				, C.EMAILADDRESS 
				, B.CELLPHONE 
			FROM PERSONGROUPTEAM A, PERSON B, EMAIL C
			WHERE A.RESPPARTY = B.PERSONID 
			AND B.PERSONID  = C.PERSONID
		)
	</sql>
	<sql id="search_conditions">
		WHERE PERSONGROUP = #{PERSONGROUP}
		<if test="PERSONID != null and PERSONID != ''">
			AND PERSONID = #{PERSONID}
		</if>
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT count(*)
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<insert id="insert" parameterType="HashMap">
		INSERT INTO TB_SR_RECEIVE_GROUP (
			TB_SR_RECEIVE_GROUPID
			, TOWER_TYPE_CD
			, EMAIL
			, NAME
			, PHONE
			, REG_USER_ID
			, REG_DT
		) VALUES (
		 	NEXTVAL FOR TB_SR_RECEIVE_GROUPIDSEQ
			, #{TOWER_TYPE_CD}
			, #{EMAIL}
			, #{NAME}
			, #{PHONE}
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		)
	</insert>
	
	<update id="update" parameterType="HashMap">
		UPDATE TB_SR_RECEIVE_GROUP SET
			NAME = #{NAME}
			, PHONE = #{PHONE}
			, UPD_USER_ID = #{UPD_USER_ID}
			, UPD_DT = CURRENT TIMESTAMP
		WHERE TOWER_TYPE_CD = #{TOWER_TYPE_CD}
		AND   EMAIL			= #{EMAIL}
	</update>
	
	<select id="findTowerGroupList" parameterType="HashMap" resultType="HashMap">
		SELECT PERSONGROUP AS CODE_ID
			, DESCRIPTION AS CODE_NM
		FROM PERSONGROUP
		WHERE HASLD = 1
		ORDER BY PERSONGROUPID 
	</select>
</mapper>