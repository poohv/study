package kr.co.kyobo.mapper.maximo.billReport;

import java.util.List;
import java.util.Map;

import org.apache.ibatis.annotations.Mapper;
import org.springframework.stereotype.Repository;

@Repository
@Mapper
public interface BillReportMapper {
	List<Map<String, Object>> findMonthList(Map<String, Object> params);
	
	List<Map<String, Object>> findPeriodList(Map<String, Object> params);
	
	List<Map<String, Object>> findTowerList(Map<String, Object> params);
}
