package kr.co.kyobo.user.controller;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpSession;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.MessageSource;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.Authentication;
import org.springframework.security.core.context.SecurityContext;
import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.ResponseBody;

import kr.co.kyobo.user.service.UserService;
import psdi.util.MXCipher;
import psdi.util.MXException;

@Controller
public class UserController {
	
	@Autowired
	private UserService userService;
	
	@Autowired
	private MessageSource messageSource;
	
	// 로그인 페이지
	@GetMapping("/user/login")
	public String login() {
		return "thymeleaf/user/login";
	}
	
//	@RequestMapping("/user/login")
//    public String login() {
//        return "thymeleaf/user/login";
//    }
    
    // 로그인 결과 페이지
    @GetMapping("/user/loginSuccess")
    public String loginSuccess() {
        return "thymeleaf/user/loginSuccess";
    }
    
    // 로그인 결과 페이지
    @GetMapping("/user/denied")
    public String denied() {
        return "thymeleaf/user/denied";
    }
    
    /**
     * 사용자 목록 조회
     * 
     * @param params
     * @return
     */
    @ResponseBody
	@RequestMapping("/user/findAll")
	public Map<String, Object> findAll(@RequestParam Map<String, Object> params) {
		Map<String, Object> resultMap = new HashMap<String, Object>();
		
		int totalCnt = userService.findCount(params);
		List<Map<String, Object>> dataList = userService.findAll(params);
		
		if(!"-1".equals(params.get("length"))){	
			resultMap.put("recordsTotal", totalCnt);
			resultMap.put("recordsFiltered", totalCnt);
			resultMap.put("data", dataList);
		}else {
			resultMap.put("recordsTotal", dataList.size());
			resultMap.put("recordsFiltered", dataList.size());
			resultMap.put("data", dataList);
		}
		
		return resultMap;
	}
	
	@ResponseBody
	@RequestMapping("/user/findOne")
	public Map<String, Object> findOne(@RequestBody Map<String, Object> params) {
		return userService.findOne(params);
	}


	/**
	 * 권한 화면 호출
	 * @param model
	 * @return
	 */
	@RequestMapping("/user/role/index")
	public String indexRole(Model model) {
		return "thymeleaf/user/role/index";
	}
	
	/**
	 * 권한목록 화면 호출
	 * @param model
	 * @return
	 */
	@RequestMapping("/user/role/list")
	public String listRole(Model model) {
		return "thymeleaf/user/role/list";
	}
    
	/**
	 * 사용자 권한 등록
	 * 
	 * @param params
	 * @return
	 * @throws Exception
	 */
	@ResponseBody
	@RequestMapping("/user/role/registData")
	public Map<String, Object> registRole(@RequestBody Map<String, Object> params) throws Exception {
		Map<String, Object> resultMap = new HashMap<String, Object>();
		resultMap.put("result", messageSource.getMessage("msg.result.success", null, null));
		resultMap.put("resultMsg", messageSource.getMessage("msg.regist.success", null, null));
		
		int resultCnt = userService.insertUserRole(params);
			
		if(resultCnt == 0) {
			resultMap.put("result", messageSource.getMessage("msg.result.fail", null, null));
			resultMap.put("resultMsg", messageSource.getMessage("msg.regist.fail", null, null));
		}
		
		return resultMap;
	}
	
	/**
	 * 사용자 권한그룹 목록 조회
	 * 
	 * @param params
	 * @return
	 */
	@ResponseBody
	@RequestMapping("/user/role/findUserRoleList")
	public List<Map<String, Object>> findUserRoleList(@RequestParam Map<String, Object> params) {
		return userService.findUserRoleList(params);
	}
	
	/**
	 * 권한그룹별 사용자 목록 조회
	 * 
	 * @param params
	 * @return
	 */
	@ResponseBody
	@RequestMapping("/user/role/findUserListByRole")
	public List<Map<String, Object>> findUserListByRole(@RequestParam Map<String, Object> params) {
		return userService.findUserListByRole(params);
	}
	
	// 로그인 결과 페이지
	@RequestMapping("/sso/login")
    public String ssoLogin() {
        return "/sso/login_exec";
    }
	
	/**
	 * SSO 로그인 처리
	 * 
	 * @param params
	 * @return
	 * @throws MXException 
	 */
	@RequestMapping("/sso/login/exec")
	public String ssoLoginExec(@RequestParam Map<String, Object> params
			, HttpServletRequest request) throws MXException {
		MXCipher dec = new MXCipher("DESede","CBC","PKCS5Padding", "Sa#qk5usfmMI-@2dbZP9`jL3", "beLd7$lB");
		Map<String, Object> conditions = new HashMap<String, Object>();
		
		String ssoId = request.getSession().getAttribute("SSO_ID").toString();
		
		conditions.put("LOGINID", ssoId);
		
		Map<String, Object> userInfo = userService.findLoginUser(conditions);
		
		String password = dec.decData((byte[])userInfo.get("PASSWORD"));
		
		UserDetails userDetails = userService.loadUserByUsername(userInfo.get("LOGINID").toString());
		Authentication authentication = new UsernamePasswordAuthenticationToken(userDetails, password, userDetails.getAuthorities());
	
		SecurityContext securityContext = SecurityContextHolder.getContext();
		securityContext.setAuthentication(authentication);
		HttpSession session = request.getSession(true);
		session.setAttribute("SPRING_SECURITY_CONTEXT", securityContext);
		
		return "redirect:/";
	}
}
