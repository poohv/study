<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.sr.SrMapper">
	<sql id="search_query">
		SELECT *
		FROM (
			SELECT SR_ID
				, SR_TITLE
				, REQ_USER_ID
				, REQ_PHONE
				, REQ_EMAIL
				, VARCHAR_FORMAT(REQ_DT,'YYYY/MM/DD') AS REQ_DT
				, PROC_USER_ID
				, VARCHAR_FORMAT(PROC_DT,'YYYY/MM/DD') AS PROC_DT
				, PROC_TYPE_CD
				, FN_GET_CODE_NM('PROC_TYPE', PROC_TYPE_CD) AS PROC_TYPE_CD_NM
				, VARCHAR_FORMAT(START_DT,'YYYY/MM/DD') AS START_DT
				, PRIORITY_CD
				, FN_GET_CODE_NM('PRIORITY', PRIORITY_CD) AS PRIORITY_CD_NM
				, REASON
				, ATTACH_ID
				, PERSONGROUP
				, REG_USER_ID
				, VARCHAR_FORMAT(REG_DT, 'YYYY/MM/DD') AS REG_DT
				, UPD_USER_ID
				, VARCHAR_FORMAT(UPD_DT, 'YYYY/MM/DD') AS UPD_DT
			FROM TB_SR
		)
	</sql>
	<sql id="search_conditions">
		WHERE 1=1
		<if test="REQ_DT != null and REQ_DT != ''">
			AND REQ_DT = #{REQ_DT}
		</if>
		<if test="PRIORITY_CD != null and PRIORITY_CD != ''">
			AND PRIORITY_CD = #{PRIORITY_CD}
		</if>
		<if test="PROC_TYPE_CD != null and PROC_TYPE_CD != ''">
			AND PROC_TYPE_CD = #{PROC_TYPE_CD}
		</if>
		<if test="SR_TITLE != null and SR_TITLE != ''">
			AND SR_TITLE LIKE '%' || UPPER(#{SR_TITLE}) || '%'
		</if>
		<if test="SR_ID != null and SR_ID != ''">
			AND SR_ID = #{SR_ID}
		</if>
		ORDER BY SR_ID DESC
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT count(*)
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<sql id="search_detail_query">
		SELECT *
		FROM (
			SELECT SR_ID
				, A.ORDER_NO
				, CONTRACT_TYPE_CD
				, FN_GET_CODE_NM('CONTRACT_TYPE', CONTRACT_TYPE_CD) AS CONTRACT_TYPE_CD_NM
				, CONTRACT_NO
				, A.BASELINE_ID
				, FN_GET_CODE_NM('RESOURCE_TYPE', B.RESOURCE_TYPE_CD) AS RESOURCE_TYPE_NM
				, FN_GET_CODE_NM('RESOURCE_CATEGORY', B.RESOURCE_CATEGORY_CD) AS RESOURCE_CATEGORY_CD_NM
				, VARCHAR_FORMAT(QUANTITY, '999,999,999,999') AS QUANTITY
				, B.UNITS
				, RATE_TYPE_CD
				, FN_GET_CODE_NM('RATE_TYPE', RATE_TYPE_CD) AS RATE_TYPE_CD_NM
				, SR_TYPE_CD
				, FN_GET_CODE_NM('SR_TYPE', SR_TYPE_CD) AS SR_TYPE_CD_NM
				, VARCHAR_FORMAT(START_DT,'YYYY/MM/DD') AS START_DT
				, PROC_TYPE_CD
				, FN_GET_CODE_NM('PROC_TYPE', PROC_TYPE_CD) AS PROC_TYPE_CD_NM
				, VARCHAR_FORMAT(CAST(A.AMOUNT AS DEC(16,0)), '999,999,999,999') AS AMOUNT
				, REMARK
				, A.REG_USER_ID
				, VARCHAR_FORMAT(A.REG_DT, 'YYYY/MM/DD') AS REG_DT
				, A.UPD_USER_ID
				, VARCHAR_FORMAT(A.UPD_DT, 'YYYY/MM/DD') AS UPD_DT
				, A.PROC_TYPE_CD 
			FROM TB_SR_LIST A, TB_BILL_RESOURCE B
			WHERE A.BASELINE_ID = B.BASELINE_ID(+)
		)
	</sql>
	<sql id="search_detail_conditions">
		WHERE 1=1
		<if test="SR_ID != null and SR_ID != ''">
			AND SR_ID = #{SR_ID}
		</if>
	</sql>
	
	<select id="findDetailAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_detail_query"></include>
			<include refid="search_detail_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
		ORDER BY ORDER_NO
	</select>
	
	<sql id="search_receive_query">
		SELECT *
		FROM (
			SELECT SR_ID
				, EMAIL_RECEIVE_TYPE_CD
				, FN_GET_CODE_NM('EMAIL_RECEIVE_TYPE', EMAIL_RECEIVE_TYPE_CD) AS EMAIL_RECEIVE_TYPE_CD_NM
				, EMAIL
			FROM TB_SR_RECEIVE_USER
		)
	</sql>
	<sql id="search_receive_conditions">
		WHERE 1=1
		<if test="SR_ID != null and SR_ID != ''">
			AND SR_ID = #{SR_ID}
		</if>
	</sql>
	
	<select id="findReceiveAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_receive_query"></include>
			<include refid="search_receive_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
		ORDER BY EMAIL_RECEIVE_TYPE_CD
	</select>
	
	<insert id="insert" parameterType="HashMap">
		<selectKey resultType="string" keyProperty="SR_ID" order="BEFORE">
			SELECT COALESCE(
				(SELECT SUBSTRING(MAX(SR_ID), 1, 9) || LPAD(CAST(SUBSTRING(MAX(SR_ID), 10, 4) AS INT) + 1, 4, '0')
				FROM TB_SR
				WHERE SUBSTRING(SR_ID, 4 ,6) = VARCHAR_FORMAT(CURRENT TIMESTAMP, 'YYYYMM'))
				, 'PSR' || VARCHAR_FORMAT(CURRENT TIMESTAMP, 'YYYYMM') || '0001')
			FROM "SYSIBM".SYSDUMMY1
		</selectKey>
		INSERT INTO TB_SR (
			TB_SRID
			,SR_ID
			,SR_TITLE
			,REQ_USER_ID
			,REQ_PHONE
			,REQ_EMAIL
			,REQ_DT
			,PROC_USER_ID
			,PROC_DT
			,PROC_TYPE_CD
			,START_DT
			,PRIORITY_CD
			,REASON
			,ATTACH_ID
			,PERSONGROUP
			,REG_USER_ID
			,REG_DT
		) VALUES (
		 	NEXTVAL FOR TB_SRIDSEQ
			, #{SR_ID}
			, #{SR_TITLE}
			, #{REQ_USER_NM}
			, #{REQ_PHONE}
			, #{REQ_EMAIL}
			, DATE(TO_DATE(REPLACE(#{REQ_DT}, '/', ''), 'YYYYMMDD'))
			, #{PROC_USER_ID}
			, #{PROC_DT}
			, '001'
			, DATE(TO_DATE(REPLACE(#{START_DT}, '/', ''), 'YYYYMMDD'))
			, #{PRIORITY_CD}
			, #{REASON}
			, #{ATTACH_ID}
			, #{PERSONGROUP}
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		)
	</insert>
	
	<update id="update" parameterType="HashMap">
		UPDATE TB_SR SET
			PROC_TYPE_CD = #{PROC_TYPE_CD}
			, UPD_USER_ID = #{UPD_USER_ID}
			, UPD_DT = CURRENT TIMESTAMP
		WHERE SR_ID = #{SR_ID}
	</update>
	
	<insert id="insertDetail" parameterType="HashMap">
		INSERT INTO TB_SR_LIST (
			TB_SR_LISTID
			,SR_ID
			,ORDER_NO
			,CONTRACT_TYPE_CD
			,CONTRACT_NO
			,BASELINE_ID
			,QUANTITY
			,RATE_TYPE_CD
			,SR_TYPE_CD
			,START_DT
			,PROC_TYPE_CD
			,AMOUNT
			,REMARK
		) VALUES 
		<foreach collection="detailList" item="detail" separator=",">
			(
				NEXTVAL FOR TB_SR_LISTIDSEQ
				, #{SR_ID}
				, #{detail.ORDER_NO}
				, #{detail.CONTRACT_TYPE_CD}
				, #{detail.CONTRACT_NO}
				, #{detail.BASELINE_ID}
				, CAST(REPLACE(#{detail.QUANTITY}, ',', '') AS INTEGER)
				, #{detail.RATE_TYPE_CD}
				, #{detail.SR_TYPE_CD}
				, DATE(TO_DATE(REPLACE(#{detail.START_DT}, '/', ''), 'YYYYMMDD'))
				, '001'
				, CAST(REPLACE(#{detail.AMOUNT}, ',', '') AS DECIMAL(16, 3))
				, #{detail.REMARK}
			)
		</foreach>
	</insert>
	
	<update id="updateDetail" parameterType="HashMap">
		UPDATE TB_SR_LIST
		SET PROC_TYPE_CD = #{PROC_TYPE_CD}
		WHERE SR_ID = #{SR_ID}
		AND ORDER_NO = #{ORDER_NO}
	</update>
	
	<insert id="insertReceiveUser" parameterType="HashMap">
		INSERT INTO TB_SR_RECEIVE_USER (
			TB_SR_RECEIVE_USERID
			,SR_ID
			,EMAIL_RECEIVE_TYPE_CD
			,EMAIL
			,REG_USER_ID
			,REG_DT
		) VALUES 
		<foreach collection="toList" item="to" separator=",">
			(
				NEXTVAL FOR TB_SR_RECEIVE_USERIDSEQ
				, #{SR_ID}
				, #{to.EMAIL_RECEIVE_TYPE_CD}
				, #{to.EMAIL}
				, #{to.REG_USER_ID}
				, CURRENT TIMESTAMP
			)
		</foreach>
	</insert>
	
</mapper>