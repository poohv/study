<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.hst.RateHstMapper">
	<sql id="search_query">
		SELECT A.HIST_SEQ
			, A.CONTRACT_TYPE_CD
			, FN_GET_CODE_NM('CONTRACT_TYPE', A.CONTRACT_TYPE_CD) AS CONTRACT_TYPE_CD_NM
			, A.CONTRACT_NO
			, A.BASELINE_ID
			, VARCHAR_FORMAT(TO_DATE(A.SVC_MONTH, 'YYYYMM'), 'YYYY/MM') AS SVC_MONTH
			, A.RATE
			, A.RATE_TYPE_CD
			, FN_GET_CODE_NM('RATE_TYPE', A.RATE_TYPE_CD) AS RATE_TYPE_CD_NM
			, A.BASE_YN
			,(SELECT FN_GET_CODE_NM('RESOURCE_TYPE', RESOURCE_TYPE_CD) AS RESOURCE_TYPE_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS RESOURCE_TYPE_CD_NM
			,(SELECT FN_GET_CODE_NM('TOWER_TYPE', TOWER_TYPE_CD) AS TOWER_TYPE_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS TOWER_TYPE_CD_NM
			,(SELECT FN_GET_CODE_NM('REPORT_CATEGORY', REPORT_CATEGORY_CD) AS REPORT_CATEGORY_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS REPORT_CATEGORY_CD_NM
			,(SELECT FN_GET_CODE_NM('RESOURCE_CATEGORY', RESOURCE_CATEGORY_CD) AS RESOURCE_CATEGORY_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS RESOURCE_CATEGORY_CD_NM
			, VARCHAR_FORMAT(A.REG_DT, 'YYYY-MM-DD HH24:MI') AS REG_DT
		FROM TB_BILL_RATE_HIST A
		WHERE 1=1
		AND A.CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND A.CONTRACT_NO = #{CONTRACT_NO}
		AND A.RATE_TYPE_CD = #{RATE_TYPE_CD}
		AND A.HIST_SEQ = #{HIST_SEQ}
		AND BASE_YN = 'N'
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
		SELECT A.HIST_SEQ
			, A.CONTRACT_TYPE_CD
			, FN_GET_CODE_NM('CONTRACT_TYPE', A.CONTRACT_TYPE_CD) AS CONTRACT_TYPE_CD_NM
			, A.CONTRACT_NO
			, A.BASELINE_ID
			, VARCHAR_FORMAT(TO_DATE(A.SVC_MONTH, 'YYYYMM'), 'YYYY/MM') AS SVC_MONTH
			, CASE WHEN A.RATE = 0 THEN '' ELSE VARCHAR_FORMAT(CAST(A.RATE AS DEC(16,2)), '999,999,999,999.00') END AS RATE
			, A.RATE_TYPE_CD
			, FN_GET_CODE_NM('RATE_TYPE', A.RATE_TYPE_CD) AS RATE_TYPE_CD_NM
			, A.BASE_YN
			,(SELECT FN_GET_CODE_NM('RESOURCE_TYPE', RESOURCE_TYPE_CD) AS RESOURCE_TYPE_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS RESOURCE_TYPE_CD_NM
			,(SELECT FN_GET_CODE_NM('TOWER_TYPE', TOWER_TYPE_CD) AS TOWER_TYPE_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS TOWER_TYPE_CD_NM
			,(SELECT FN_GET_CODE_NM('REPORT_CATEGORY', REPORT_CATEGORY_CD) AS REPORT_CATEGORY_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS REPORT_CATEGORY_CD_NM
			,(SELECT FN_GET_CODE_NM('RESOURCE_CATEGORY', RESOURCE_CATEGORY_CD) AS RESOURCE_CATEGORY_CD_NM FROM TB_BILL_RESOURCE B WHERE B.BASELINE_ID = A.BASELINE_ID) AS RESOURCE_CATEGORY_CD_NM
			, VARCHAR_FORMAT(A.REG_DT, 'YYYY-MM-DD HH24:MI') AS REG_DT
		FROM TB_BILL_RATE_HIST A
		WHERE 1=1
		AND A.CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND A.CONTRACT_NO = #{CONTRACT_NO}
		AND A.RATE_TYPE_CD = #{RATE_TYPE_CD}
		AND A.HIST_SEQ = #{HIST_SEQ}
		AND BASE_YN = 'N'
		<if test="length!=null and !length.equals('')">
			LIMIT ${length}
			OFFSET ${start}
		</if>
		) A
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT count(*)
		FROM (
			<include refid="search_query"></include>
		) A
	</select>
	
</mapper>