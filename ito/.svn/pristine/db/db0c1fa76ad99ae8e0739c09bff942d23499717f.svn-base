package kr.co.kyobo.user.service;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.core.GrantedAuthority;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.security.core.userdetails.User;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.security.core.userdetails.UserDetailsService;
import org.springframework.security.core.userdetails.UsernameNotFoundException;
import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import kr.co.kyobo.mapper.maximo.user.UserMapper;
import lombok.extern.slf4j.Slf4j;
import psdi.util.MXCipher;
import psdi.util.MXException;

@Service
public class UserService implements UserDetailsService {
	
	@Autowired
	public UserMapper userMapper;

	@Override
	public UserDetails loadUserByUsername(String username) throws UsernameNotFoundException {
		BCryptPasswordEncoder encoder = new BCryptPasswordEncoder();
		
		List<GrantedAuthority> authorities = null;
		String loginId = "";
		String loginPw = "";
		
		try {
			MXCipher dec = new MXCipher("DESede","CBC","PKCS5Padding", "Sa#qk5usfmMI-@2dbZP9`jL3", "beLd7$lB");
			
			authorities = new ArrayList<>();
			
			Map<String, Object> conditions = new HashMap<String, Object>();
			conditions.put("LOGINID", username);
			
			Map<String, Object> loginInfo = userMapper.findLoginUser(conditions);
			
			if(loginInfo != null) {
				loginId = loginInfo.get("LOGINID").toString();
				loginPw = dec.decData((byte[])loginInfo.get("PASSWORD"));
				
				List<Map<String, Object>> loginRoleList = userMapper.findLoginUserRoleList(conditions);
				
				for (Map<String, Object> map : loginRoleList) {
					authorities.add(new SimpleGrantedAuthority(map.get("GROUPNAME").toString()));
				}
			}
			
		} catch (MXException e) {
			e.printStackTrace();
		}

        return new User(loginId, encoder.encode(loginPw), authorities);
	}
	
	public int findCount(Map<String, Object> params) {
		return userMapper.findCount(params);
	}
	
	public List<Map<String, Object>> findAll(Map<String, Object> params) {
		return userMapper.findAll(params);
	}
	
	public Map<String, Object> findOne(Map<String, Object> params) {
		return userMapper.findOne(params);
	}

	public List<Map<String, Object>> findUserRoleList(Map<String, Object> params) {
		return userMapper.findUserRoleList(params);
	}
	
	public List<Map<String, Object>> findUserListByRole(Map<String, Object> params) {
		return userMapper.findUserListByRole(params);
	}
	
	@Transactional(rollbackFor = Exception.class)
	public int insertUserRole(Map<String, Object> insertData) throws Exception {
		int resultCnt = 1;
		
		try {
			// 삭제
			resultCnt += userMapper.deleteUserRole(insertData);
			
			// 등록
			List<Map<String, Object>> userList = (List<Map<String, Object>>)insertData.get("userList");
			
			if(userList.size() > 0) {
				resultCnt += userMapper.insertUserRole(insertData);
				
				if(resultCnt == 0) {
					throw new Exception("Exception for rollback");
				}
			}
		} catch(Exception e) {
			throw e;
		}
		
		return resultCnt;
	}
}
