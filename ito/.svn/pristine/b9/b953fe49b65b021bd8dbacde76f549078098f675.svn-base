package kr.co.kyobo.bill.rate.service;

import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import kr.co.kyobo.mapper.maximo.bill.RateMapper;

@Service
public class RateService {

	@Autowired
	public RateMapper rateMapper;
	
	public int findCount(Map<String, Object> params) {
		return rateMapper.findCount(params);
	}
	
	public List<Map<String, Object>> findAll(Map<String, Object> params) {
		return rateMapper.findAll(params);
	}
	
	public int insert(Map<String, Object> insertData) {
		int resultCnt = 0;
		
		// 이력 저장
		resultCnt += rateMapper.insertHist(insertData);
		
		// 기존 데이터 삭제
		resultCnt += rateMapper.delete(insertData);
		
		// 데이터 저장
		resultCnt += rateMapper.insert(insertData);
		
		return resultCnt;
	}
	
	public Integer findAmount(Map<String, Object> params) {
		return rateMapper.findAmount(params);
	}
}
