<!DOCTYPE html>
<html layout:decorator="thymeleaf/layout/layout_blank">
<head>
<title layout:title-pattern="$LAYOUT_TITLE : $CONTENT_TITLE">[(#{title.contract.amount})] - [(#{title.list})]</title>
</head>
<body>
	<div layout:fragment="content">
		<section class="content">
			<div class="container-fluid mt-2">
				<div class="row">
					<div class="col-lg-12">
						<div class="card card-primary card-outline">
							<div class="card-header">
								<h5 class="card-title m-0" data-th-text="#{title.search}"></h5>
							</div>
							<div class="card-body">
								<form id="search-form" class="form-horizontal">
									<div class="row">
										<div class="col-sm-4">
											<!-- text input -->
											<div class="form-group row">
												<label for="CONTRACT_TYPE_CD" class="col-sm-4 col-form-label" data-th-text="#{label.contract.contractType}"></label>
												<div class="col-sm-8">
													<select id="CONTRACT_TYPE_CD" name="CONTRACT_TYPE_CD"
														class="form-control select2" required="required">
														<option value="" selected="selected"
															data-th-text="#{label.common.all}"></option>
													</select>
												</div>
											</div>
										</div>
										<div class="col-sm-4">
											<!-- text input -->
											<div class="form-group row">
												<label for="CONTRACT_NO" class="col-sm-4 col-form-label" data-th-text="#{label.contract.contractTypeNo}"></label>
												<div class="col-sm-8">
													<input type="text" id="CONTRACT_NO" name="CONTRACT_NO" class="form-control" required="required">
												</div>
											</div>
										</div>
									</div>
									<div class="row">
										<div class="col-sm-12">
											<div class="text-center">
												<button type="submit" class="btn btn-sm btn-primary" data-th-text="#{button.search}"></button>
												<button type="button" class="btn btn-sm btn-outline-primary" data-action-button="reset" data-th-text="#{button.reset}"></button>
											</div>
										</div>
									</div>
								</form>
							</div>
						</div>
					</div>
					<!-- /.col-lg-12 -->
				</div>
				<!-- /.row -->

				<div class="row">
					<div class="col-lg-12">
						<div class="card card-primary card-outline">
							<div class="card-header">
								<h3 class="card-title" data-th-text="#{title.list}"></h3>
								<div class="card-tools">
									<button type="button" class="btn btn-sm btn-success" data-action-button="save">[(#{button.save})]</button>
								</div>
							</div>
							<!-- /.card-header -->
							<div class="card-body">
								<form id="data-form">
									<table id="dataTable" class="table table-sm table-bordered table-hover table-striped">
										<thead>
											<tr>
												<th data-th-text="#{label.contract.amount.contractType}"></th>
												<th data-th-text="#{label.contract.amount.contractTypeNo}"></th>
												<th data-th-text="#{label.contract.amount.svcMonth}"></th>
												<th data-th-text="#{label.contract.amount.amount}"></th>
											</tr>
										</thead>
									</table>
								</form>
							</div>
							<!-- /.card-body -->
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>

	<th:block layout:fragment="script">
		<script>
			$(function() {
				var form = $("#search-form");
				var dataForm = $("#data-form");
				var validator = form.validate({
					errorPlacement: function(error, element) {
						if ( element.hasClass( "select2" )) {
							$(element).next().find('span span').addClass('is-invalid');
						}
					}
				});
				var selectedRowData;
				
				// 공통코드 콤보박스 생성
				$('select[name="CONTRACT_TYPE_CD"]').createSelectBox({
					code_id : 'CONTRACT_TYPE'
				});

				// 조회결과 테이블 생성
				var dataTable = $('#dataTable').createDataTable({
					url: _ctx + "/bill/contractAmount/dataList",
					params: {},
					bPaginate: false,
					dom: '<"float-right"i>frt',
					columns: [
						{data : "CONTRACT_TYPE_CD"},
						{data : "CONTRACT_NO"},
						{data : "SVC_MONTH"},
						{data : "AMOUNT"}
					],
					columnDefs: [
						{ targets: [0], visible: false },
						{ targets: [1], visible: false },
						{
							targets: [2],
							className: 'text-center',
							render: function ( data, type, full ) {
								return '<span>'+data+'</span><input type="hidden" name="SVC_MONTH" value="'+data+'">';
							}
						},
						{
							targets: [3],
							className: 'text-center',
							render: function ( data, type, full ) {
								var inputGroup = '';
								inputGroup += '<div class="input-group">';
								inputGroup += '    <input type="text" name="AMOUNT" class="form-control contract-amount" value="'+data+'">';
								inputGroup += '    <span class="input-group-append">';
								inputGroup += '        <button type="button" class="btn btn-outline-primary" data-action-button="setDown"><i class="fas fa-arrow-down"></i></button>';
								inputGroup += '    </span>';
								inputGroup += '    <span class="input-group-append">';
								inputGroup += '        <button type="button" class="btn btn-outline-primary" data-action-button="setUp"><i class="fas fa-arrow-up"></i></button>';
								inputGroup += '    </span>';
								inputGroup += '</div>';
								
								return inputGroup;
							}
						}
					],
					callback: function() {
						// 금액 마스크 처리
						$('.contract-amount').inputmask('numeric', {
							groupSeparator: ',',
							autoGroup: true
						});
					}
				});
				
				// 폼 전송 이벤트
				form.submit(function(e) {
				    e.preventDefault();
				    
				    if(!validator.valid()) return false;
				    
				    $(this).find('.select2').next().find('span span').removeClass('is-invalid');
				    
				    $.fn.executeAction('search');
				});
				
				// 프로세스 처리 함수
				$.fn.executeAction = function(procType) {
					switch(procType) {
						case 'clearResult' :	// 조회결과 초기화
							$('#dataTable tbody').html('<tr><td valign="top" colspan="2" class="dataTables_empty">[(#{msg.empty.data})]</td></tr>');
							
							break;
						case 'reset' :			// 조회조건 초기화
							form[0].reset();
							form.find("select").trigger("change");
							
							$.fn.executeAction('clearResult');
							
							break;
						case 'setDown' :		// 아래로 적용
							var selectedIdx = $('#dataTable [data-action-button="setDown"]').index(this);
							var selectedAmt = $('#dataTable [name="AMOUNT"]').eq(selectedIdx).val();
							$('#dataTable [name="AMOUNT"]').each(function(idx, item) {
								if(idx > selectedIdx) {
									$(this).val(selectedAmt);
								}
							});
						
							break;
						case 'setUp' :			// 위로 적용
							var selectedIdx = $('#dataTable [data-action-button="setUp"]').index(this);
							var selectedAmt = $('#dataTable [name="AMOUNT"]').eq(selectedIdx).val();
							$('#dataTable [name="AMOUNT"]').each(function(idx, item) {
								if(idx < selectedIdx) {
									$(this).val(selectedAmt);
								}
							});
						
							break;
						case 'save' :			// 저장
							var svcMonthArr = new Array();
							var amountArr = new Array();
							
							$('#dataTable [name="SVC_MONTH"]').each(function(idx, item) {
								svcMonthArr.push($(this).val().replace(/\//g, ''));
							});
							
							$('#dataTable [name="AMOUNT"]').each(function(idx, item) {
								amountArr.push($(this).val().replace(/\,/g, ''));
							});
							
							var formData = {};
							$(form).serializeArray().map(function(x) {formData[x.name] = x.value;});
							formData['SVC_MONTH'] = svcMonthArr.join(',');
							formData['AMOUNT'] = amountArr.join(',');
							
							// 폼 데이터 전송
							$.sendData({
								url: '/bill/contractAmount/registData',
								data: formData,
								notification: true,
								isIframe: true
							});
						
							break;
						case 'search' :			// 조회
							var dataTableParams = form.serialize();
					    	dataTable.ajax.url(_ctx + '/bill/contractAmount/dataList?' + dataTableParams).draw();
							break;
						default :
							;
					}
				}
				
				// 버튼 이벤트
				$(document).on('click', '[data-action-button]', function() {
					$(this).executeAction($(this).data('action-button'));
				});
			});
		</script>
	</th:block>
</body>
</html>