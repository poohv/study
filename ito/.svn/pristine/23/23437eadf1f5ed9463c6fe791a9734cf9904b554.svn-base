<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.hst.ContractAmountHstMapper">
	<sql id="search_query">
		SELECT *
		FROM (
		SELECT A.HIST_SEQ
			, A.CONTRACT_TYPE_CD
			, A.CONTRACT_NO
			, FN_GET_CODE_NM('CONTRACT_TYPE', A.CONTRACT_TYPE_CD) AS CONTRACT_TYPE_CD_NM
			, VARCHAR_FORMAT(TO_DATE(A.SVC_MONTH, 'YYYYMM'), 'YYYY/MM') AS SVC_MONTH
			, CASE WHEN A.AMOUNT = 0 THEN '' ELSE VARCHAR_FORMAT(CAST(A.AMOUNT AS DEC(16,2)), '999,999,999,999.00') END AS AMOUNT
			, A.REG_USER_ID
			, VARCHAR_FORMAT(A.REG_DT, 'YYYY-MM-DD HH24:MI') AS REG_DT
		FROM TB_CONTRACT_AMOUNT_HIST A
		WHERE 1=1
		AND A.CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND A.CONTRACT_NO = #{CONTRACT_NO}
		AND A.HIST_SEQ = #{HIST_SEQ}
		) A
	</sql>
	
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
		SELECT A.HIST_SEQ
			, A.CONTRACT_TYPE_CD
			, A.CONTRACT_NO
			, FN_GET_CODE_NM('CONTRACT_TYPE', A.CONTRACT_TYPE_CD) AS CONTRACT_TYPE_CD_NM
			, VARCHAR_FORMAT(TO_DATE(A.SVC_MONTH, 'YYYYMM'), 'YYYY/MM') AS SVC_MONTH
			, CASE WHEN A.AMOUNT = 0 THEN '' ELSE VARCHAR_FORMAT(CAST(A.AMOUNT AS DEC(16,2)), '999,999,999,999.00') END AS AMOUNT
			, A.REG_USER_ID
			, VARCHAR_FORMAT(A.REG_DT, 'YYYY-MM-DD HH24:MI') AS REG_DT
		FROM TB_CONTRACT_AMOUNT_HIST A
		WHERE 1=1
		AND A.CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND A.CONTRACT_NO = #{CONTRACT_NO}
		AND A.HIST_SEQ = #{HIST_SEQ}
		<if test="length!=null and !length.equals('')">
			LIMIT ${length}
			OFFSET ${start}
		</if>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT count(*)
		FROM (
			<include refid="search_query"></include>
		) A
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
		) A
	</select>
</mapper>