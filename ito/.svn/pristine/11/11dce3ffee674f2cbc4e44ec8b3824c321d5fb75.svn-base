<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.bill.BaseLineMapper">
	<sql id="search_query">
		SELECT BASELINE_ID
			, FN_GET_RESOURCE_CATEGORY_NM('RESOURCE_CATEGORY', BASELINE_ID) AS RESOURCE_CATEGORY_CD_NM
			, QUANTITY
			, BASE_YN
			, VARCHAR_FORMAT(DATE(TO_DATE(SVC_MONTH, 'YYYYMM')), 'YYYY/MM') AS SVC_MONTH
		FROM TB_BILL_BASELINE
	</sql>
	<sql id="search_conditions">
		<where>
			<if test="BASELINE_ID != null and BASELINE_ID != ''">
				AND BASELINE_ID = #{BASELINE_ID}
			</if>
			<if test="SVC_MONTH != null and SVC_MONTH != ''">
				AND SVC_MONTH = REPLACE(#{SVC_MONTH}, '/', '')
			</if>
			<if test="BASE_YN != null and BASE_YN != ''">
				AND BASE_YN = #{BASE_YN}
			</if>
		</where>
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT COUNT(*)
		FROM (
			<include refid="search_query"></include>
		)
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<insert id="insert" parameterType="HashMap">
		INSERT INTO TB_BILL_BASELINE (
			TB_BILL_BASELINEID
			, BASELINE_ID
			, SVC_MONTH
			, BASE_YN
			, QUANTITY
			, REG_USER_ID
			, REG_DT
		) VALUES (
			NEXTVAL FOR TB_BILL_BASELINEIDSEQ
			, #{BASELINE_ID}
			, REPLACE(#{SVC_MONTH}, '/', '')
			, #{BASE_YN}
			, CASE WHEN '' = REPLACE(#{QUANTITY}, ',', '') THEN '0' 
				ELSE REPLACE(#{QUANTITY}, ',', '')
				END
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		)
	</insert>
	
	<delete id="delete" parameterType="HashMap">
		DELETE FROM TB_BILL_BASELINE
		WHERE BASELINE_ID = #{BASELINE_ID}
		AND BASE_YN = #{BASE_YN}
		AND SVC_MONTH = REPLACE(#{SVC_MONTH}, '/', '')
	</delete>
	
	<insert id="insertHist" parameterType="HashMap">
		INSERT INTO TB_BILL_BASELINE_HIST (
			TB_BILL_BASELINE_HISTID
			, HIST_SEQ
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, BASELINE_ID
			, SVC_MONTH
			, BASE_YN
			, QUANTITY
			, REG_USER_ID
			, REG_DT
		) 
		SELECT NEXTVAL FOR TB_BILL_BASELINE_HISTIDSEQ
			, (
				SELECT COALESCE(MAX(HIST_SEQ), 0) + 1
				FROM TB_BILL_BASELINE_HIST
				WHERE BASELINE_ID = #{BASELINE_ID}
				AND SVC_MONTH = REPLACE(#{SVC_MONTH}, '/', '')
			)
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, BASELINE_ID
			, SVC_MONTH
			, BASE_YN
			, QUANTITY
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		FROM TB_BILL_BASELINE
		WHERE BASELINE_ID = #{BASELINE_ID}
		AND BASE_YN = #{BASE_YN}
		AND SVC_MONTH = REPLACE(#{SVC_MONTH}, '/', '')
	</insert>
</mapper>