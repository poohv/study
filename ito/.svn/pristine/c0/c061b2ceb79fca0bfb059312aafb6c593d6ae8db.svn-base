var _ctx = '';

$(function() {
	"use strict";
	
	_ctx = $('meta[name="ctx"]').attr('content');
	
	/**
	 * 정합성 체크
	 */
	$.validator.setDefaults({
		errorPlacement: function ( error, element ) {
			error.addClass('invalid-feedback');
			
			// 콤보
			if ( element.hasClass( "select2" )) {
				error.insertAfter( element.next() );
				$(element).next().find('span span').addClass('is-invalid');
			// 달력
			} else if ( element.hasClass( "datetimepicker-input" )
					|| element.hasClass( "datetimepicker-range" )) {
				error.insertAfter( element.next() );
			// 파일
			} else if ( element.hasClass( "custom-file-input" )) {
				error.insertAfter( element.parent().parent() );
			} else {
				if ( element.prop( "type" ) === "checkbox" ) {
					error.insertAfter( element.parent( "label" ) );
				} else {
					error.insertAfter( element );
				}
			}
		},
		highlight: function (element, errorClass, validClass) {
			$(element).addClass('is-invalid');
		},
		unhighlight: function (element, errorClass, validClass) {
			$(element).removeClass('is-invalid');
			
			// 콤보
			if ( $(element).hasClass( "datetimepicker-input" )) {
				$(element).next().find('span span').removeClass('is-invalid');
			}
		}
	});
	
	/**
	 * 날짜 입력 컴포넌트
	 */
	$.fn.createDatePicker = function(options) {
		$(this).datetimepicker({
			viewMode: options['viewMode'] ? options['viewMode'] : 'days',
			format: options['format'] ? options['format'] : 'YYYY/MM/DD',
			inline: options['inline'] ? options['inline'] : false,
			defaultDate: options['defaultDate'] ? options['defaultDate'] : false
		});
	};
	
	/**
	 * 기간 입력 컴포넌트
	 */
	$.fn.createDateRangePicker = function(options) {
		$(this).daterangepicker({
			startDate: options['startDate'] ? options['startDate'] : new Date(),
			endDate: options['endDate'] ? options['endDate'] : new Date(),
			showDropdowns: options['showDropdowns'] ? options['showDropdowns'] : false,
			locale: {
				format: options['format'] ? options['format'] : 'YYYY/MM/DD'
			}
		});
	};
	
	/**
	 * 탭바
	 */
	$.fn.createTabs = function(options) {
		var contentIframe;
		var _this = this;
		
		var resizeTabUI = function(iframe) {
			var headerBar = $('.main-header');
		    var sideBar = $('.main-sidebar');
		    var footerBar = $('.main-footer');
		    var tabHeader = $(_this).find('.tabs-header');

		    if(iframe) {
				var calcHeight = $(headerBar).outerHeight() + $(footerBar).outerHeight() + $(tabHeader).outerHeight();
				
				if($(_this).hasClass('easyui-tabs-sub')) {
					calcHeight = $(tabHeader).outerHeight();
				}
				
				$(iframe).css({height: 'calc(100vh - ' + calcHeight + 'px)'});
				$(_this).tabs('resize',{});
			} else {
				$(_this).find('iframe').each(function(idx) {
					var calcHeight = $(headerBar).outerHeight() + $(footerBar).outerHeight() + $(tabHeader).outerHeight();
					
					if($(_this).hasClass('easyui-tabs-sub')) {
						calcHeight = $(tabHeader).outerHeight();
					}
					
					$(this).css({height: 'calc(100vh - ' + calcHeight + 'px)'});
					$(_this).tabs('resize',{});
				});
			}
		};
		
		if($(_this).tabs('exists', options['title'])) {
			$(_this).tabs('select', options['title'])
		} else {
			if(options['isIframe']) {
				var iframeUrl = options['url'];
				iframeUrl += '?' + $.param(options['sendData']);
				
				contentIframe = $('<iframe></iframe>').attr('id', options['id']).attr('src', iframeUrl).attr('style', 'display:block;border:0;width:100%;height:100%;');
				
				$(contentIframe).on('load', function() {
			    	resizeTabUI(this);
				});
			} else {
				contentIframe = options['content'] ? options['content'] : '';
			}
			
			$(_this).tabs(options['method'],{
				title: options['title'],
				content: contentIframe,
				closable: options['closable'],
				tools:[{
					iconCls:'icon-mini-refresh',
					handler:function(){
						$('#' + options['id']).get(0).contentWindow.location.reload();
					}
				}]
			});
		}
		
		$(window).resize(function(){
			resizeTabUI();
	    });
	}
	
	/**
	 * 콤보박스 생성
	 * options: {
	 * 		url: 미입력시 공통코드 조회
	 * 		code_id: 공통코드ID
	 * 		params: 파라미터
	 * }
	 */
	$.fn.createSelectBox = function(options) {
		var url = _ctx + '/api/code/';
		var selectBox;
		
		if(!options) {
			selectBox = $(this).select2();
		} else {
		    // 특정 url 호출일 경우
		    if(options['url']) {
		    	url = options['url'];
		    // 공통코드 호출일 경우
		    } else {
		    	if(!options['code_id']) return;
		    	
		    	url += options['code_id'];
		    }
		    
			selectBox = $(this).select2({
				width: options['width'] ? options['width'] : '100%',
				minimumResultsForSearch: options['minimumResultsForSearch'] ? options['minimumResultsForSearch'] : '',
				ajax: {
					url: url,
					delay: 250,
					cache: false,
					data: function(params) {
						return {
							CODE_NM: params.term,
							page: params.page
						}
					},
					processResults: function (data) {
						var data = $.map(data, function (obj) {
							obj.id = obj.id || obj.CODE_ID;
							obj.text = obj.text || obj.CODE_NM;
						
							return obj;
						});
						
						return {
						  results: data
						}
					}
				}
			});
		}
		
		return selectBox;
	};
	
	/**
	 * 데이터 테이블 생성
	 * options: {
	 * 		url: '요청URL',
	 * 		params: {
	 * 			a: '',					//요청파라미터
	 * 			b: ''					//요청파라미터
	 * 		},
	 * 		columns: [
	 * 			{data : "WORD"},		//컬럼명
	 * 			{data : "WORD_READ"},	//컬럼명
	 * 			{data : "KOR"}			//컬럼명
	 * 		]
	 * }
	 */
	$.fn.createDataTable = function(options) {
		if(!options) return false;
		
		var newexportaction = function(e, dt, button, config) {
		    var self = this;
		    var oldStart = dt.settings()[0]._iDisplayStart;
		    dt.one('preXhr', function (e, s, data) {
		        // Just this once, load all data from the server...
		        data.start = 0;
		        data.length = 2147483647;
		        dt.one('preDraw', function (e, settings) {
		            // Call the original action function
		            if (button[0].className.indexOf('buttons-copy') >= 0) {
		                $.fn.dataTable.ext.buttons.copyHtml5.action.call(self, e, dt, button, config);
		            } else if (button[0].className.indexOf('buttons-excel') >= 0) {
		                $.fn.dataTable.ext.buttons.excelHtml5.available(dt, config) ?
		                    $.fn.dataTable.ext.buttons.excelHtml5.action.call(self, e, dt, button, config) :
		                    $.fn.dataTable.ext.buttons.excelFlash.action.call(self, e, dt, button, config);
		            } else if (button[0].className.indexOf('buttons-csv') >= 0) {
		                $.fn.dataTable.ext.buttons.csvHtml5.available(dt, config) ?
		                    $.fn.dataTable.ext.buttons.csvHtml5.action.call(self, e, dt, button, config) :
		                    $.fn.dataTable.ext.buttons.csvFlash.action.call(self, e, dt, button, config);
		            } else if (button[0].className.indexOf('buttons-pdf') >= 0) {
		                $.fn.dataTable.ext.buttons.pdfHtml5.available(dt, config) ?
		                    $.fn.dataTable.ext.buttons.pdfHtml5.action.call(self, e, dt, button, config) :
		                    $.fn.dataTable.ext.buttons.pdfFlash.action.call(self, e, dt, button, config);
		            } else if (button[0].className.indexOf('buttons-print') >= 0) {
		                $.fn.dataTable.ext.buttons.print.action(e, dt, button, config);
		            }
		            dt.one('preXhr', function (e, s, data) {
		                // DataTables thinks the first item displayed is index 0, but we're not drawing that.
		                // Set the property to what it was before exporting.
		                settings._iDisplayStart = oldStart;
		                data.start = oldStart;
		            });
		            // Reload the grid with the original page. Otherwise, API functions like table.cell(this) don't work properly.
		            setTimeout(dt.ajax.reload, 0);
		            // Prevent rendering of the full data to the DOM
		            return false;
		        });
		    });
		    // Requery the server with the new one-time export settings
		    dt.ajax.reload();
		};
		
		var dataTableOptions = {
			language: {
			   "sEmptyTable":     "데이터가 없습니다",
			   "sInfo":           "_START_ - _END_ / _TOTAL_",
			   "sInfoEmpty":      "0 - 0 / 0",
			   "sInfoFiltered":   "(총 _MAX_ 개)",
			   "sInfoPostFix":    "",
			   "sInfoThousands":  ",",
			   "sLengthMenu":     "페이지당 줄수 _MENU_",
			   "sLoadingRecords": "읽는중...",
			   "sProcessing":     "처리중...",
			   "sSearch":         "검색:",
			   "sZeroRecords":    "검색 결과가 없습니다",
			   "oPaginate": {
			       "sFirst":    "처음",
			       "sLast":     "마지막",
			       "sNext":     "다음",
			       "sPrevious": "이전"
			   },
			   "oAria": {
			       "sSortAscending":  ": 오름차순 정렬",
			       "sSortDescending": ": 내림차순 정렬"
			   }
			},
			dom: options['dom'] ? options['dom'] : 'B<"float-right"l>frtip',
	        buttons: {
	        	dom: {
	                button: {
	                    className: 'btn btn-xs btn-secondary'
	                }
	            },
	        	buttons: options['buttons'] ? options['buttons'] : [
		        	{
		                extend : 'excel',
		                action: newexportaction
		            },
		            {
		                extend : 'csv',
		                charset: 'UTF-8',
		                bom: true,
		                action: newexportaction
		            },
		            {
		                extend : 'copy',
		                action: newexportaction
		            },
		            {
		                extend : 'print',
		                action: newexportaction
		            }
		        ]
	        },
	        pagingType : "full_numbers",
	        searching : false,
			ordering: false,
			autoWidth: false,
			bPaginate: (options['bPaginate'] != undefined) ? options['bPaginate'] : true,
			columns : options['columns'],
			columnDefs: options['columnDefs'],
	        drawCallback: function(settings) {
	        	if(options['callback']) options['callback']();
	        }
		};
		
		if(options['url']) {
			dataTableOptions['responsive'] = true;
			dataTableOptions['processing'] = true;
			dataTableOptions['serverSide'] = true;
			dataTableOptions['ajax'] = {
				type : "POST",
				url : options['url'],
				dataType : "json",
				data: options['params']
			};
		}
		
		var dataTable = $(this).DataTable(dataTableOptions);
		
		return dataTable;
	};
	
	/**
	 * 팝업
	 */
	$.fn.createPopup = function(options) {
		var _this = this;
		var _id = $(_this).attr('id');
		var modalId = ((_id == undefined) ? options['type'] : $(_this).attr('id')) + '_POPUP';
		var modalOptions = {
			title: options['title'] ? options['title'] + ' 팝업' : '팝업',
			content: options['content'] ? options['content'] : ''
		};
		
		var modalContent = '';
		
		modalContent += '<div class="modal fade" id="' + modalId + '">';
		modalContent += '	<div class="modal-dialog modal-lg">';
		modalContent += '		<div class="modal-content">';
		modalContent += '			<div class="modal-header">';
		modalContent += '				<h4 class="modal-title">' + modalOptions['title'] + '</h4>';
		modalContent += '				<button type="button" class="close" data-dismiss="modal" aria-label="Close">';
		modalContent += '					<span aria-hidden="true">&times;</span>';
		modalContent += '				</button>';
		modalContent += '			</div>';
		modalContent += '			<div class="modal-body">' + modalOptions['content'] + '</div>';
		modalContent += '			<div class="modal-footer justify-content-between">';
		modalContent += '				<button type="button" class="btn btn-default" data-dismiss="modal">닫기</button>';
		modalContent += '			</div>';
		modalContent += '		</div>';
		modalContent += '	</div>';
		modalContent += '</div>';
		
		$(document).on('hide.bs.modal', '#' + modalId, function() {
			$('#' + modalId).remove();
			$('#' + modalId).next('.modal-backdrop').remove();
			$('#' + modalId).parent().removeClass('modal-open');
		});
		
		if(options && options['type']) {
			// 베이스라인
			if('baseline' == options['type']) {
				$(_this).next().on('click', 'button', function() {
					$(document).find('body').append(modalContent);
					$('#' + modalId).modal({backdrop: 'static'});
					
					var baselineContent = '';
					baselineContent += '<div class="card">';
					baselineContent += '	<div class="card-body">';
					baselineContent += '		<form id="' + modalId + '-search-form" class="form-horizontal">';
					baselineContent += '			<div class="row">';
					baselineContent += '				<div class="col-sm-5">';
					baselineContent += '					<div class="form-group row">';
					baselineContent += '						<label for="RESOURCE_TYPE_CD" class="col-sm-4 col-form-label">리소스 타입</label>';
					baselineContent += '						<div class="col-sm-8">';
					baselineContent += '							<select id="RESOURCE_TYPE_CD" name="RESOURCE_TYPE_CD" class="form-control select2">';
					baselineContent += '								<option value="" selected="selected">전체</option>';
					baselineContent += '							</select>';
					baselineContent += '						</div>';
					baselineContent += '					</div>';
					baselineContent += '				</div>';
					baselineContent += '				<div class="col-sm-7">';
					baselineContent += '					<div class="form-group row">';
					baselineContent += '						<label for="RESOURCE_CATEGORY_CD_NM" class="col-sm-4 col-form-label">리소스 카테고리</label>';
					baselineContent += '						<div class="col-sm-8">';
					baselineContent += '							<input type="search" id="RESOURCE_CATEGORY_CD_NM" name="RESOURCE_CATEGORY_CD_NM" class="form-control">';
					baselineContent += '						</div>';
					baselineContent += '					</div>';
					baselineContent += '				</div>';
					baselineContent += '			</div>';
					baselineContent += '			<div class="row">';
					baselineContent += '				<div class="col-sm-12">';
					baselineContent += '					<div class="text-center">';
					baselineContent += '						<button type="submit" class="btn btn-sm btn-primary">조회</button>';
					baselineContent += '						<button type="button" class="btn btn-sm btn-outline-primary" data-action-button="reset">초기화</button>';
					baselineContent += '					</div>';
					baselineContent += '				</div>';
					baselineContent += '			</div>';
					baselineContent += '		</form>';
					baselineContent += '	</div>';
					baselineContent += '</div>';
					baselineContent += '<table id="' + modalId + '-dataTable" class="table table-sm table-bordered table-hover table-striped">';
					baselineContent += '	<thead>';
					baselineContent += '		<tr>';
					baselineContent += '			<th>리소스타입</th>';
					baselineContent += '			<th>타워구분</th>';
					baselineContent += '			<th>리포트 카테고리</th>';
					baselineContent += '			<th>리소스 카테고리</th>';
					baselineContent += '			<th>단위</th>';
					baselineContent += '		</tr>';
					baselineContent += '	</thead>';
					baselineContent += '</table>';
					
					$('#' + modalId).find('.modal-body').html(baselineContent);
					
					// 행 선택 이벤트
					$('#' + modalId + '-dataTable').on('dblclick', 'tbody tr', function(e) {
						if(options['callback']) {
							options['callback']({
								BASELINE_ID: $('#' + modalId + '-dataTable [name="BASELINE_ID"]').eq($(this).index()).val(),
								RESOURCE_CATEGORY_CD_NM: $('#' + modalId + '-dataTable [name="RESOURCE_CATEGORY_CD_NM"]').eq($(this).index()).val(),
								UNITS: $('#' + modalId + '-dataTable [name="UNITS"]').eq($(this).index()).val(),
							});
						} else {
							$('[name="' + options['code_id'] + '"]').val($('#' + modalId + '-dataTable [name="BASELINE_ID"]').eq($(this).index()).val());
							$('[name="' + options['code_nm'] + '"]').val($('#' + modalId + '-dataTable [name="RESOURCE_CATEGORY_CD_NM"]').eq($(this).index()).val());
						}
						
						$('#' + modalId).modal('hide');
					}).on('mouseover', 'tbody tr', function(e) {
						$(this).css('cursor', 'pointer');
					});
					
					var form = $('#' + modalId + '-search-form');
					var validator = form.validate({
						errorPlacement: function(error, element) {
							if ( element.hasClass( "select2" )) {
								$(element).next().find('span span').addClass('is-invalid');
							}
						}
					});
					
					// 조회 조건 폼
					form.find('select[name="RESOURCE_TYPE_CD"]').createSelectBox({
						code_id : 'RESOURCE_TYPE'
					});
					
					// 폼 전송 이벤트
					form.submit(function(e) {
					    e.preventDefault();
					    $.fn.executePopupAction('search');
					});
					
					// 조회 결과 테이블
					var dataTable = $('#' + modalId + '-dataTable').createDataTable({
						url: _ctx + "/bill/resource/dataList",
						params: {},
						dom: 'ftip',
						columns: [
							{data : "RESOURCE_TYPE_CD_NM"},
							{data : "TOWER_TYPE_CD_NM"},
							{data : "REPORT_CATEGORY_CD_NM"},
							{data : "RESOURCE_CATEGORY_CD_NM"},
							{data : "UNITS"}
						],
						columnDefs: [
							{
								targets: [0],
								className: 'text-center',
								render: function ( data, type, full ) {
									var rowContent = '';
									rowContent += '<span>'+data+'</span>';
									rowContent += '<input type="hidden" name="BASELINE_ID" value="'+full['BASELINE_ID']+'">';
									rowContent += '<input type="hidden" name="RESOURCE_CATEGORY_CD_NM" value="'+full['RESOURCE_CATEGORY_CD_NM']+'">';
									rowContent += '<input type="hidden" name="UNITS" value="'+full['UNITS']+'">';
									return rowContent;
								}
							},
							{
								targets: [1],
								className: 'text-center'
							},							
							{
								targets: [2],
								className: 'text-center'
							},
							{
								targets: [3],
								className: 'text-center'
							},							
							{
								targets: [4],
								className: 'text-center'
							}
						]
					});
					
					// 프로세스 처리 함수
					$.fn.executePopupAction = function(procType) {
						switch(procType) {
							case 'clearResult' :	// 조회결과 초기화
								$('#' + modalId + '-dataTable tbody').html('<tr><td valign="top" colspan="5" class="dataTables_empty">데이터가 업습니다.</td></tr>');
								
								break;
							case 'reset' :			// 조회조건 초기화
								form[0].reset();
								form.find("select").trigger("change");
								$.fn.executePopupAction('clearResult');
								break;
							case 'search' :
								var dataTableParams = form.serialize();
						    	dataTable.ajax.url(_ctx + '/bill/resource/dataList?' + dataTableParams).draw();
								break;
							default :
								;
						}
					}
					
					// 리소스 타입 변경 이벤트
					form.find('select[name="RESOURCE_TYPE_CD"]').on('change', function() {
						form.submit();
					});
					
					// 초기화 버튼 이벤트
					form.find('[data-action-button]').on('click', function() {
						$(this).executePopupAction($(this).data('action-button'));
					});
				});
			} else if('user' == options['type']) {
				$(document).find('body').append(modalContent);
				$('#' + modalId).modal({backdrop: 'static'});
				
				// 사용자 정보
				var baselineContent = '';
				baselineContent += '<div class="card">';
				baselineContent += '	<div class="card-body">';
				baselineContent += '		<form id="' + modalId + '-search-form" class="form-horizontal">';
				baselineContent += '			<div class="row">';
				baselineContent += '				<div class="col-sm-12">';
				baselineContent += '					<div class="form-group row">';
				baselineContent += '						<label for="KEYWORD" class="col-sm-2 col-form-label">키워드</label>';
				baselineContent += '						<div class="col-sm-10">';
				baselineContent += '							<input type="search" id="KEYWORD" name="KEYWORD" class="form-control" placeholder="아이디 or 이름 or 이메일">';
				baselineContent += '						</div>';
				baselineContent += '					</div>';
				baselineContent += '				</div>';
				baselineContent += '			</div>';
				baselineContent += '			<div class="row">';
				baselineContent += '				<div class="col-sm-12">';
				baselineContent += '					<div class="text-center">';
				baselineContent += '						<button type="submit" class="btn btn-sm btn-primary">조회</button>';
				baselineContent += '						<button type="button" class="btn btn-sm btn-outline-primary" data-action-button="reset">초기화</button>';
				baselineContent += '					</div>';
				baselineContent += '				</div>';
				baselineContent += '			</div>';
				baselineContent += '		</form>';
				baselineContent += '	</div>';
				baselineContent += '</div>';
				baselineContent += '<table id="' + modalId + '-dataTable" class="table table-sm table-bordered table-hover table-striped">';
				baselineContent += '	<thead>';
				baselineContent += '		<tr>';
				baselineContent += '			<th>아이디</th>';
				baselineContent += '			<th>이름</th>';
				baselineContent += '			<th>이메일</th>';
				baselineContent += '		</tr>';
				baselineContent += '	</thead>';
				baselineContent += '</table>';
				
				$('#' + modalId).find('.modal-body').html(baselineContent);
				
				// 행 선택 이벤트
				$('#' + modalId + '-dataTable').on('dblclick', 'tbody tr', function(e) {
					if(options['callback']) {
						options['callback'](dataTable.row(this).data());
					} else {
						$('[name="' + options['code_id'] + '"]').val($('#' + modalId + '-dataTable [name="PERSONID"]').eq($(this).index()).val());
						$('[name="' + options['code_nm'] + '"]').val($('#' + modalId + '-dataTable [name="DISPLAYNAME"]').eq($(this).index()).val());
					}
					
					$('#' + modalId).modal('hide');
				}).on('mouseover', 'tbody tr', function(e) {
					$(this).css('cursor', 'pointer');
				});
				
				var form = $('#' + modalId + '-search-form');
				var validator = form.validate();
				
				// 폼 전송 이벤트
				form.submit(function(e) {
				    e.preventDefault();
				    $.fn.executePopupAction('search');
				});
				
				// 조회 결과 테이블
				var dataTable = $('#' + modalId + '-dataTable').createDataTable({
					url: _ctx + "/user/findAll",
					params: {},
					dom: 'ftip',
					columns: [
						{data : "PERSONID", visible: false},
						{data : "DISPLAYNAME"},
						{data : "EMAILADDRESS"}
					],
					columnDefs: [
						{
							targets: [1],
							className: 'text-center'
						}
					]
				});
				
				// 프로세스 처리 함수
				$.fn.executePopupAction = function(procType) {
					switch(procType) {
						case 'clearResult' :	// 조회결과 초기화
							$('#' + modalId + '-dataTable tbody').html('<tr><td valign="top" colspan="5" class="dataTables_empty">데이터가 업습니다.</td></tr>');
							
							break;
						case 'reset' :			// 조회조건 초기화
							form[0].reset();
							$.fn.executePopupAction('clearResult');
							break;
						case 'search' :
							var dataTableParams = form.serialize();
					    	dataTable.ajax.url(_ctx + '/user/findAll?' + dataTableParams).draw();
							break;
						default :
							;
					}
				}
				
				// 초기화 버튼 이벤트
				form.find('[data-action-button]').on('click', function() {
					$(this).executePopupAction($(this).data('action-button'));
				});
			}
		}
	};
	
	// AJAX 전송
	$.sendData = function(options, callback) {
		var _data;
		
		if(options['type'] && options['type'].toUpperCase() == 'GET') {
			_data = options['data'];
		} else {
			_data = JSON.stringify(options['data']) ? JSON.stringify(options['data']) : '{}'
		}
		
		$.ajax({
			type: options['type'] ? options['type'] : 'POST',
			url: _ctx + options['url'],
			async: (options['async'] != undefined) ? options['async'] : true,
			data: _data,
			contentType: 'application/json',
			success: function(data) {
				// 메시지 출력
				if(options['notification']
						&& options['notification'] === true) {
					if(data['resultMsg']) {
						if(data['result'] == 'S') {
							parent.parent.toastr.success(data['resultMsg']);
						} else {
							parent.parent.toastr.error(data['resultMsg']);
						}
					}
				}
				
				// 콜백처리
				if(callback) {
					callback(data);
				}
			},
			error: function(xhr, textStatus, errorThrown) {
//				console.log(xhr);
//				console.log(textStatus);
//				console.log(errorThrown);
				parent.parent.toastr.error(xhr.responseJSON['message']);
			}
		});
	}
	
	// AJAX 첨부파일 전송
	$.sendAttachData = function(options, callback) {
		$.ajax({
			type: 'POST',
			url: _ctx + options['url'],
			async: (options['async'] != undefined) ? options['async'] : true,
			data: options['data'],
			processData: false,
			contentType: false,
			success: function(data) {
				// 메시지 출력
				if(options['notification']
						&& options['notification'] === true) {
					if(data['resultMsg']) {
						if(data['result'] == 'S') {
							parent.parent.toastr.success(data['resultMsg']);
						} else {
							parent.parent.toastr.error(data['resultMsg']);
						}
					}
				}
				
				// 콜백처리
				if(callback) {
					callback(data);
				}
			},
			error: function(xhr, textStatus, errorThrown) {
//				console.log(xhr);
//				console.log(textStatus);
//				console.log(errorThrown);
				parent.parent.toastr.error(xhr.responseJSON['message'].split(';')[0]);
			}
		});
	}
	
	/**
	 * 메시지
	 */
	$.showAlert = function(options) {
		if(options) {
			if('success' == options['type']) {
				parent.parent.toastr.success(options['msg']);
			} else if('warning' == options['type']) {
				parent.parent.toastr.warning(options['msg']);
			} else if('error' == options['type']) {
				parent.parent.toastr.error(options['msg']);
			}
		}
	}
	
	/**
	 * 로딩 이미지
	 * type: dark, null
	 * display: true, false
	 */
	$.fn.loading = function(options) {
		var loadingHtml = '';
		loadingHtml += '<div class="load-icon overlay ' + options['type'] + '">';
		loadingHtml += '	<i class="fas fa-3x fa-sync-alt fa-spin"></i>';
		loadingHtml += '</div>';
		
		if(options) {
			if(options['display'] === true) {
				$(this).append(loadingHtml);
			} else {
				$(this).find('.overlay').remove();
			}
		}
	}
	
	/**
	 * 천단위 콤마
	 */
	$.setComma = function(data) {
		var result = '';
		
		if(isNaN(data)) {
			result = data;
		} else {
			result = data.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
		}
		
		return result;
	}
});