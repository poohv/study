package kr.co.kyobo.billReport.service;

import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import kr.co.kyobo.mapper.maximo.billReport.BillReportMapper;

@Service
public class BillReportService {
	
	@Autowired
	public BillReportMapper billReportMapper;
	
	public List<Map<String, Object>> findMonthList(Map<String, Object> params) {
		return billReportMapper.findMonthList(params);
	}
	
	public List<Map<String, Object>> findPeriodList(Map<String, Object> params) {
		return billReportMapper.findPeriodList(params);
	}
	
	public List<Map<String, Object>> findTowerList(Map<String, Object> params) {
		return billReportMapper.findTowerList(params);
	}
}
