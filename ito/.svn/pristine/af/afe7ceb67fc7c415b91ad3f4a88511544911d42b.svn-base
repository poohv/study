package kr.co.kyobo.word.controller;

import java.util.HashMap;

import org.springframework.http.ResponseEntity;
import org.springframework.security.core.Authentication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
public class WordApiController {

	@GetMapping("/api/hello")
    public ResponseEntity<?> hello(Authentication authentication) {
		
        return ResponseEntity.ok(
                new HashMap<String, Object>() {{
                    put("currentUser", String.format("Hello!! %s", authentication.getName()));
                }}
        );
    }
	
	@GetMapping("/api/admin/index")
    public ResponseEntity<?> helloManager(Authentication authentication) {

        return ResponseEntity.ok(
                new HashMap<String, Object>() {{
                    put("currentUser", String.format("Hello admin!! %s", authentication.getName()));
                }}
        );
    }
}
