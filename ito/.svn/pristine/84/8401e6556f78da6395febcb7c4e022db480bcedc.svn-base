<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.bill.ContractAmountMapper">
	
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		WITH MONTH_RANGE(CONTRACT_MONTHS) AS (
			SELECT DATE(TO_DATE(START_DATE, 'YYYYMMDD')) AS CONTRACT_MONTHS
			FROM TB_CONTRACT
			WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
			AND CONTRACT_NO = #{CONTRACT_NO}
			UNION ALL
			SELECT DATE(CONTRACT_MONTHS) + 1 MONTH AS CONTRACT_MONTHS 
			FROM MONTH_RANGE
			WHERE CONTRACT_MONTHS <![CDATA[<=]]> (
				SELECT DATE(TO_DATE(END_DATE, 'YYYYMMDD')) - 1 MONTH
				FROM TB_CONTRACT
				WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
				AND CONTRACT_NO = #{CONTRACT_NO}
			)
		)
		SELECT VARCHAR_FORMAT(CONTRACT_MONTHS, 'YYYY/MM') AS SVC_MONTH
			, COALESCE(B.CONTRACT_TYPE_CD, '') AS CONTRACT_TYPE_CD
			, COALESCE(B.CONTRACT_NO, '') AS CONTRACT_NO
			, COALESCE(B.AMOUNT, 0) AS AMOUNT
		FROM MONTH_RANGE A, (
			SELECT *
			FROM TB_CONTRACT_AMOUNT
			WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
			AND CONTRACT_NO = #{CONTRACT_NO}
		) B
		WHERE VARCHAR_FORMAT(A.CONTRACT_MONTHS, 'YYYYMM') = B.SVC_MONTH(+)
	</select>
	
	<insert id="insert" parameterType="HashMap">
		INSERT INTO TB_CONTRACT_AMOUNT (
			TB_CONTRACT_AMOUNTID
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, SVC_MONTH
			, AMOUNT
			, REG_USER_ID
			, REG_DT
		) VALUES 
		<foreach collection="amountList" item="amount" separator=",">
			(
				NEXTVAL FOR TB_CONTRACT_AMOUNTIDSEQ
				, #{amount.CONTRACT_TYPE_CD}
				, #{amount.CONTRACT_NO}
				, REPLACE(#{amount.SVC_MONTH}, '/', '')
				, CASE WHEN '' = REPLACE(#{amount.AMOUNT}, ',', '') THEN '0' 
					ELSE REPLACE(#{amount.AMOUNT}, ',', '')
					END
				, #{amount.REG_USER_ID}
				, CURRENT TIMESTAMP
			)
		</foreach>
	</insert>
	
	<delete id="delete" parameterType="HashMap">
		DELETE FROM TB_CONTRACT_AMOUNT
		WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND CONTRACT_NO = #{CONTRACT_NO}
	</delete>
	
	<insert id="insertHist" parameterType="HashMap">
		INSERT INTO TB_CONTRACT_AMOUNT_HIST (
			TB_CONTRACT_AMOUNT_HISTID
			, HIST_SEQ
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, SVC_MONTH
			, AMOUNT
			, REG_USER_ID
			, REG_DT
		)
		SELECT NEXTVAL FOR TB_CONTRACT_AMOUNT_HISTIDSEQ
			, (
				SELECT COALESCE(MAX(HIST_SEQ), 0) + 1
				FROM TB_CONTRACT_AMOUNT_HIST
				WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
				AND CONTRACT_NO = #{CONTRACT_NO}
			)
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, SVC_MONTH
			, AMOUNT
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		FROM TB_CONTRACT_AMOUNT
		WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND CONTRACT_NO = #{CONTRACT_NO}
	</insert>
</mapper>