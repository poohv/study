<!DOCTYPE html>
<html layout:decorator="thymeleaf/layout/layout_blank">
<head>
<title layout:title-pattern="$LAYOUT_TITLE : $CONTENT_TITLE">[(#{title.rateHst})] - [(#{title.list})]</title>
</head>
<body>
	<div layout:fragment="content">
		<section class="content">
			<div class="container-fluid mt-2">
				<div class="row">
					<div class="col-lg-12">
						<div class="card card-primary card-outline">
							<div class="card-header">
								<h5 class="card-title m-0" data-th-text="#{title.search}"></h5>
							</div>
							<div class="card-body">
								<form id="search-form" class="form-horizontal">
									<input type="hidden" name="BASELINE_ID">
									<div class="row">
										<div class="col-sm-4">
											<!-- text input -->
											<div class="form-group row">
												<label for="RESOURCE_CATEGORY_CD_NM" class="col-sm-4 col-form-label" data-th-text="#{label.rate.resourceCategory}"></label>
												<div class="input-group col-sm-8">
							                        <input type="text" id="RESOURCE_CATEGORY_CD_NM" name="RESOURCE_CATEGORY_CD_NM" class="form-control" required="required" readonly="readonly">
							                        <div class="input-group-append">
							                            <button type="button" class="btn btn-default"><i class="fas fa-search"></i></button>
													</div>
							                    </div>
											</div>
										</div>
										<div class="col-sm-4">
											<div class="form-group row">
												<label for="SVC_MONTH" class="col-sm-4 col-form-label" data-th-text="#{label.baseLine.svcMonth}"></label>
												<div class="col-sm-8">
													<div class="input-group" id="SVC_MONTH" data-target-input="nearest">
								                        <input type="text" name="SVC_MONTH" class="form-control datetimepicker-input" data-toggle="datetimepicker" data-target="#SVC_MONTH" required="required">
								                        <div class="input-group-append" data-target="#SVC_MONTH" data-toggle="datetimepicker">
								                            <div class="input-group-text d-block"><i class="fa fa-calendar"></i></div>
								                        </div>
								                    </div>
							                    </div>
											</div>
										</div>
										<div class="col-sm-4">
											<!-- text input -->
											<div class="form-group row">
												<label for="BASE_YN" class="col-sm-4 col-form-label" data-th-text="#{label.rate.baseYn}"></label>
												<div class="col-sm-8">
													<div class="icheck-primary form-check form-check-inline">
														<input type="radio" id="BASE_Y" name="BASE_YN" class="form-check-input" value= "Y" checked>
														<label for="BASE_Y" class="form-check-label">[(#{label.common.yes})]
														</label>
													</div>
													<div class="icheck-primary form-check form-check-inline">
														<input type="radio" id="BASE_N" name="BASE_YN" class="form-check-input" value= "N">
														<label for="BASE_N" class="form-check-label">[(#{label.common.no})]
														</label>
													</div>
												</div>
											</div>
										</div>
									</div>
									<div class="row">
										<div class="col-sm-12">
											<div class="text-center">
												<button type="submit" class="btn btn-sm btn-primary" data-th-text="#{button.search}"></button>
												<button type="button" class="btn btn-sm btn-outline-primary" data-action-button="reset" data-th-text="#{button.reset}"></button>
											</div>
										</div>
									</div>
								</form>
							</div>
						</div>
					</div>
					<!-- /.col-lg-12 -->
				</div>
				<!-- /.row -->

				<div class="row">
					<div class="col-lg-12">
						<div class="card card-primary card-outline">
							<div class="card-header">
								<h3 class="card-title" data-th-text="#{title.list}"></h3>
							</div>
							<!-- /.card-header -->
							<div class="card-body">
								<form id="data-form">
									<table id="dataTable" class="table table-sm table-bordered table-hover table-striped">
										<thead>
											<tr>
												<th data-th-text="#{label.rate.baseYn}"></th>
												<th data-th-text="#{label.resource.resourceTypeCdNm}"></th>
												<th data-th-text="#{label.resource.towerTypeNm}"></th>
												<th data-th-text="#{label.resource.reportCategoryNm}"></th>
												<th data-th-text="#{label.resource.resourceCategoryNm}"></th>
												<th data-th-text="#{label.rate.rateType}"></th>
												<th data-th-text="#{label.rate.svcMonth}"></th>
												<th data-th-text="#{label.rate.rate}"></th>
												<th data-th-text="#{label.baseLineHst.regDt}"></th>
											</tr>
										</thead>
									</table>
								</form>
							</div>
							<!-- /.card-body -->
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>

	<th:block layout:fragment="script">
		<script>
			$(function() {
				var form = $("#search-form");
				var dataForm = $("#data-form");
				var validator = form.validate({
					errorPlacement: function(error, element) {
						if ( element.hasClass( "select2" )) {
							$(element).next().find('span span').addClass('is-invalid');
						}
					}
				});
				
				// 년월
				$('#SVC_MONTH').createDatePicker({
					format: 'YYYY/MM',
					mode: 'months'
				});
				
				// 팝업 생성
				$('#RESOURCE_CATEGORY_CD_NM').createPopup({
					type: 'baseline',
					title: '리소스 카테고리',
					code_id: 'BASELINE_ID',
					code_nm: 'RESOURCE_CATEGORY_CD_NM'
				});

				// 조회결과 테이블 생성
				var dataTable = $('#dataTable').createDataTable({
					url: _ctx + "/hst/rateHst/dataList",
					params: {},
					/* responsive: false,
					processing: false,
					serverSide: false,
					bPaginate: false, */
					columns: [
						{data : "BASE_YN"},
						{data : "RESOURCE_TYPE_CD_NM"},
						{data : "TOWER_TYPE_CD_NM"},
						{data : "REPORT_CATEGORY_CD_NM"},
						{data : "RESOURCE_CATEGORY_CD_NM"},
						{data : "RATE_TYPE_CD_NM"},
						{data : "SVC_MONTH"},
						{data : "RATE"},
						{data : "REG_DT"}
					],
					columnDefs: [
						{
							targets: [0],
							className: 'text-center',
							render: function ( data, type, full ) {
								var colContent = '';
								colContent += '<span>'+full['BASE_YN']+'</span>';
								colContent += '<input type="hidden" name="BASELINE_ID" value="'+full['BASELINE_ID']+'">';
								colContent += '<input type="hidden" name="RATE_TYPE_CD" value="'+full['RATE_TYPE_CD']+'">';
								colContent += '<input type="hidden" name="SVC_MONTH" value="'+full['SVC_MONTH']+'">';
								return colContent;
							}
						},
						{
							targets: [1],
							className: 'text-center'
						},
						{
							targets: [2],
							className: 'text-center'
						},
						{
							targets: [3],
							className: 'text-center'
						},
						{
							targets: [4],
							className: 'text-center'
						},
						{
							targets: [5],
							className: 'text-center'
						},
						{
							targets: [6],
							className: 'text-center'
						},
						{
							targets: [7],
							className: 'text-center'
						},
						{
							targets: [8],
							className: 'text-center'
						}
					],
					callback: function() {
						// 금액 마스크 처리
						$('.contract-rate').inputmask('numeric', {
							groupSeparator: ',',
							autoGroup: true
						});
					}
				});
				
				// 폼 전송 이벤트
				form.submit(function(e) {
				    e.preventDefault();
				    
				    if($('[name="RESOURCE_CATEGORY_CD_NM"]').val() == '') {
				    	alert("리소스 카테고리를 선택해주세요.");
				    	return false;
				    }
				    if($('[name="SVC_MONTH"]').val() == '') {
				    	alert("날짜를 선택해주세요.");
				    	return false;
				    }
				    
				    $(this).find('.select2').next().find('span span').removeClass('is-invalid');
				    
				    $.fn.executeAction('search');
				});
				
				// 프로세스 처리 함수
				$.fn.executeAction = function(procType) {
					switch(procType) {
						case 'clearResult' :	// 조회결과 초기화
							$('#dataTable tbody').html('<tr><td valign="top" colspan="6" class="dataTables_empty">[(#{msg.empty.data})]</td></tr>');
							
							break;
						case 'reset' :			// 조회조건 초기화
							form[0].reset();
							form.find('[type="hidden"]').val('');
							form.find("select").trigger("change");
							
							$.fn.executeAction('clearResult');
							
							break;
						case 'search' :			// 조회
							var dataTableParams = form.serialize();
					    	dataTable.ajax.url(_ctx + '/hst/rateHst/dataList?' + dataTableParams).draw();
							break;
						default :
							;
					}
				}
				
				// 버튼 이벤트
				$(document).on('click', '[data-action-button]', function() {
					$(this).executeAction($(this).data('action-button'));
				});
			});
		</script>
	</th:block>
</body>
</html>