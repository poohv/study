<html>
<!--configFragment 선언-->
<th:block th:fragment="configFragment">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<!-- Context path -->
	<meta name="ctx" th:content="${#httpServletRequest.getContextPath()}">
	<!-- Font Awesome -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/fontawesome-free/css/all.min.css}">
	<!-- Ionicons -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/ionicons-2.0.1/css/ionicons.min.css}">
	<!-- Select2 -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/select2/css/select2.min.css}">
	<link rel="stylesheet" th:href="@{/adminlte/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css}">
	<!-- iCheck for checkboxes and radio inputs -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css}">
	<!-- date-range-picker -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/daterangepicker/daterangepicker.css}">
	<!-- Tempusdominus Bbootstrap 4 -->
  	<link rel="stylesheet" th:href="@{/adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css}">
	<!-- Toastr -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/toastr/toastr.min.css}">
	<!-- DataTables -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css}">
	<link rel="stylesheet" th:href="@{/adminlte/plugins/datatables-responsive/css/responsive.bootstrap4.min.css}">
	<link rel="stylesheet" th:href="@{/adminlte/plugins/datatables-buttons/css/buttons.bootstrap4.min.css}">
	<!-- Overlay Scrollbar -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/overlayScrollbars/css/OverlayScrollbars.min.css}">
	<!-- EasyUI Tabs -->
	<link rel="stylesheet" th:href="@{/adminlte/plugins/jquery-easyui-1.9.6/themes/bootstrap/easyui.css}">
	<link rel="stylesheet" th:href="@{/adminlte/plugins/jquery-easyui-1.9.6/themes/icon.css}">
	<!-- Theme style -->
	<link rel="stylesheet" th:href="@{/adminlte/dist/css/adminlte.min.css}">
	<!-- Common style -->
	<link rel="stylesheet" media="screen" th:href="@{/css/IoTSP.css}">
</th:block>
</html>