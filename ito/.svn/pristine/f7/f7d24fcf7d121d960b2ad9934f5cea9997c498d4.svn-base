<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.bill.BaseLineMapper">
	<sql id="search_query">
		SELECT CONTRACT_TYPE_CD
			, CONTRACT_NO
			, BASELINE_ID
			, QUANTITY
			, BASE_YN
			, SVC_MONTH
		FROM TB_BILL_BASELINE
		WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND CONTRACT_NO = #{CONTRACT_NO}
		AND BASELINE_ID = #{BASELINE_ID}
		AND BASE_YN = #{BASE_YN}
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		WITH MONTH_RANGE(CONTRACT_MONTHS) AS (
			SELECT DATE(TO_DATE(START_DATE, 'YYYYMMDD')) AS CONTRACT_MONTHS
			FROM TB_CONTRACT
			WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
			AND CONTRACT_NO = #{CONTRACT_NO}
			UNION ALL
			SELECT DATE(CONTRACT_MONTHS) + 1 MONTH AS CONTRACT_MONTHS 
			FROM MONTH_RANGE
			WHERE CONTRACT_MONTHS <![CDATA[<=]]> (
				SELECT DATE(TO_DATE(END_DATE, 'YYYYMMDD')) - 1 MONTH
				FROM TB_CONTRACT
				WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
				AND CONTRACT_NO = #{CONTRACT_NO}
			)
		)
		SELECT VARCHAR_FORMAT(CONTRACT_MONTHS, 'YYYY/MM') AS SVC_MONTH
			, B.CONTRACT_TYPE_CD
			, FN_GET_CODE_NM('CONTRACT_TYPE', #{CONTRACT_TYPE_CD}) AS CONTRACT_TYPE_CD_NM
			, COALESCE(B.CONTRACT_NO, '0') AS CONTRACT_NO
			, B.BASELINE_ID
			, FN_GET_RESOURCE_CATEGORY_NM('RESOURCE_CATEGORY', #{BASELINE_ID}) AS RESOURCE_CATEGORY_CD_NM
			, FN_GET_CODE_NM('RATE_TYPE', #{RATE_TYPE_CD}) AS RATE_TYPE_CD_NM
			, B.QUANTITY
			, B.BASE_YN
		FROM MONTH_RANGE A, (
			<include refid="search_query"></include>
		) B
		WHERE VARCHAR_FORMAT(A.CONTRACT_MONTHS, 'YYYYMM') = B.SVC_MONTH(+)
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT COUNT(*)
		FROM (
			<include refid="search_query"></include>
		)
	</select>
	
	<insert id="insert" parameterType="HashMap">
		INSERT INTO TB_BILL_BASELINE (
			TB_BILL_BASELINEID
			,CONTRACT_TYPE_CD
			, CONTRACT_NO
			, BASELINE_ID
			, SVC_MONTH
			, BASE_YN
			, QUANTITY
			, REG_USER_ID
			, REG_DT
		) VALUES 
		<foreach collection="quantityList" item="quantity" separator=",">
			(
				NEXTVAL FOR TB_BILL_BASELINEIDSEQ
				, #{quantity.CONTRACT_TYPE_CD}
				, #{quantity.CONTRACT_NO}
				, #{quantity.BASELINE_ID}
				, REPLACE(#{quantity.SVC_MONTH}, '/', '')
				, #{BASE_YN}
				, CASE WHEN '' = REPLACE(#{quantity.QUANTITY}, ',', '') THEN '0' 
					ELSE REPLACE(#{quantity.QUANTITY}, ',', '')
					END
				, #{quantity.REG_USER_ID}
				, CURRENT TIMESTAMP
			)
		</foreach>
	</insert>
	
	<delete id="delete" parameterType="HashMap">
		DELETE FROM TB_BILL_BASELINE
		WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND CONTRACT_NO = #{CONTRACT_NO}
		AND BASELINE_ID = #{BASELINE_ID}
		AND BASE_YN = #{BASE_YN}
	</delete>
	
	<insert id="insertHist" parameterType="HashMap">
		INSERT INTO TB_BILL_BASELINE_HIST (
			TB_BILL_BASELINE_HISTID
			, HIST_SEQ
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, BASELINE_ID
			, SVC_MONTH
			, BASE_YN
			, QUANTITY
			, REG_USER_ID
			, REG_DT
		)
		SELECT NEXTVAL FOR TB_BILL_BASELINE_HISTIDSEQ
			, (
				SELECT COALESCE(MAX(HIST_SEQ), 0) + 1
				FROM TB_BILL_BASELINE_HIST
				WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
				AND CONTRACT_NO = #{CONTRACT_NO}
				AND BASELINE_ID = #{BASELINE_ID}
			)
			, CONTRACT_TYPE_CD
			, CONTRACT_NO
			, BASELINE_ID
			, SVC_MONTH
			, BASE_YN
			, QUANTITY
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		FROM TB_BILL_BASELINE
		WHERE CONTRACT_TYPE_CD = #{CONTRACT_TYPE_CD}
		AND CONTRACT_NO = #{CONTRACT_NO}
		AND BASELINE_ID = #{BASELINE_ID}
		AND BASE_YN = #{BASE_YN}
	</insert>
</mapper>