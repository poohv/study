<!DOCTYPE html>
<html>
<head>
	<meta charset="UTF-8" />
	<title>ITO 서비스 포탈</title>
	<!-- 공통 css, js -->
	<th:block th:replace="thymeleaf/fragment/config-index :: configFragment"></th:block>
</head>
    
<body>
	<!-- content -->
	<div class="content" layout:fragment="content"></div>
	
	<!-- script fragment 사용 -->
	<th:block th:replace="thymeleaf/fragment/script :: scriptFragment"></th:block>
	<th:block layout:fragment="script"></th:block>
</body>
</html>