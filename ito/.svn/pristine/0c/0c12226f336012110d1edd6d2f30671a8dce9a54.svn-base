<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.tower.GroupMapper">
	<sql id="search_query">
		SELECT *
		FROM (
			SELECT SLA_GROUP_ID
				, SLA_GROUP_NM
				, ORDER_NO
				, USE_YN
				, REG_USER_ID
				, REG_DT
			FROM TB_SLA_GROUP
		)
	</sql>
	<sql id="search_conditions">
		WHERE 1=1
		<if test="SLA_GROUP_ID != null and SLA_GROUP_ID != ''">
			AND SLA_GROUP_ID = #{SLA_GROUP_ID}
		</if>
		<if test="SLA_GROUP_NM != null and SLA_GROUP_NM != ''">
			AND SLA_GROUP_NM = #{SLA_GROUP_NM}
		</if>
		<if test="USE_YN != null and USE_YN != ''">
			AND USE_YN = #{USE_YN}
		</if>
		ORDER BY ORDER_NO ASC
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT count(*)
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<insert id="insert" parameterType="HashMap">
		INSERT INTO TB_SLA_GROUP (
			TB_SLA_GROUPID
			, SLA_GROUP_ID
			, SLA_GROUP_NM
			, ORDER_NO
			, USE_YN
			, REG_USER_ID
			, REG_DT
		) VALUES (
		 	NEXTVAL FOR TB_SLA_GROUPIDSEQ
			, #{SLA_GROUP_ID}
			, #{SLA_GROUP_NM}
			, #{ORDER_NO}
			, #{USE_YN}
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		)
	</insert>
	
	<update id="update" parameterType="HashMap">
		UPDATE TB_SLA_GROUP SET
			ORDER_NO = #{ORDER_NO}
			, UPD_USER_ID = #{UPD_USER_ID}
			, UPD_DT = CURRENT TIMESTAMP
		WHERE SLA_GROUP_ID = #{SLA_GROUP_ID}
	</update>
	
	<update id="updateOrderNo" parameterType="HashMap">
		UPDATE TB_SLA_GROUP SET
			ORDER_NO = #{ORDER_NO}
			, UPD_USER_ID = #{UPD_USER_ID}
			, UPD_DT = CURRENT TIMESTAMP
		WHERE SLA_GROUP_ID = #{SLA_GROUP_ID}
	</update>
	
	<update id="saveSlaGroupId" parameterType="HashMap">
		MERGE INTO TB_SLA_GROUP A
		USING (SELECT NVL(COUNT(*),0) COUNT
				FROM TB_SLA_GROUP
				WHERE SLA_GROUP_ID = #{SLA_GROUP_ID}) B
		ON B.COUNT > 0	
		AND A.SLA_GROUP_ID = #{SLA_GROUP_ID}	
		WHEN MATCHED THEN
		UPDATE SET
			SLA_GROUP_NM = #{SLA_GROUP_NM}
			, USE_YN = #{USE_YN}
			, ORDER_NO = #{ORDER_NO}
			, UPD_USER_ID = #{UPD_USER_ID}
			, UPD_DT = CURRENT TIMESTAMP
		WHEN NOT MATCHED THEN
		INSERT (
			TB_SLA_GROUPID
			, SLA_GROUP_ID
			, SLA_GROUP_NM
			, ORDER_NO
			, USE_YN
			, REG_USER_ID
			, REG_DT
		) VALUES (
		 	NEXTVAL FOR TB_SLA_GROUPIDSEQ
			, #{SLA_GROUP_ID}
			, #{SLA_GROUP_NM}
			, #{ORDER_NO}
			, #{USE_YN}
			, #{UPD_USER_ID}
			, CURRENT TIMESTAMP
		)	
	</update>
	
</mapper>