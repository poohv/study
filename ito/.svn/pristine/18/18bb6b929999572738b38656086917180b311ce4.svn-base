<!DOCTYPE html>
<html layout:decorator="thymeleaf/layout/layout_default">
<head>
<title layout:title-pattern="$LAYOUT_TITLE : $CONTENT_TITLE">메인</title>
</head>
<body>

	<div layout:fragment="content">
		<div class="easyui-tabs" style="height: auto;"></div>
	</div>

	<th:block layout:fragment="script">
		<script>
			var tabsComp;
			
			$(function() {
				var menuId = '[(${menu_id})]';
				tabsComp = $('.easyui-tabs');
				
				/* tabsComp.createTabs({
					id: 'home',
					title: '[(#{title.home})]',
					//isIframe: true,
					//url: _ctx + '/adminlte/pages/UI/general.html',
					content: '홈',
					method: 'add',
					closable: false
				}); */
				
			    $('.nav-sidebar .nav-link[data-menu-id]').on('click', function() {
			    	var tabTitle = $(this).text();
					var tabId = $(this).data('menu-id');
					var tabContentUrl = $(this).data('menu-url');
			    	var closeable = true;
			    	
			    	// 관리자 권한이 있을경우
					if('true' == $('#isRoleAdmin').val()) {
				    	if('contract' == tabId) {
				    		closeable = false;
				    	}
					} else {
						if('sr' == tabId) {
				    		closeable = false;
				    	}
					}
			    	
			    	// 선택 메뉴 하이라이트
			    	$('.nav-sidebar .nav-link').removeClass('active');
			    	$(this).addClass('active');
			    	$(this).parent().parent().prev('.nav-link').addClass('active');
			    	$(this).parent().parent().parent().addClass('menu-open');
			    	
					tabsComp.createTabs({
						id: tabId,
						title: tabTitle,
						isIframe: true,
						url: _ctx + tabContentUrl,
						method: 'add',
						closable: closeable
					});
				});
			    
				if(menuId) {
			    	$('.nav-sidebar .nav-link[data-menu-id="' + menuId + '"]').click();
			    } else {
					// 관리자 권한이 있을경우
					if('true' == $('#isRoleAdmin').val()) {
				    	$('.nav-sidebar .nav-link[data-menu-id="contract"]').click();
					} else {
						$('.nav-sidebar .nav-link[data-menu-id="sr"]').click();
					}
			    }
			});
		</script>
	</th:block>
</body>
</html>