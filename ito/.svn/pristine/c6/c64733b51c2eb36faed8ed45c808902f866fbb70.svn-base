<!DOCTYPE html>
<html layout:decorator="thymeleaf/layout/layout_blank">
<head>
<title layout:title-pattern="$LAYOUT_TITLE : $CONTENT_TITLE">[(#{title.code})] - [(#{title.list})]</title>
</head>
<body>
	<div layout:fragment="content">
	<input type="hidden" id="SEQ" name="SEQ" class="form-control" required="required">
		<section class="content">
			<div class="container-fluid mt-2">
				<div class="row">
					<div class="col-lg-12">
						<div class="card card-primary card-outline">
							<div class="card-header">
								<h5 class="card-title m-0" data-th-text="#{title.search}"></h5>
							</div>
							<div class="card-body">
								<form id="search-form" class="form-horizontal">
									<div class="row">
										<div class="col-sm-4">
											<!-- text input -->
											<div class="form-group row">
												<label for="DOMAINID" class="col-sm-4 col-form-label" data-th-text="#{label.code.domainId}"></label>
												<div class="col-sm-8">
													<select id="DOMAINID" name="DOMAINID"
														class="form-control select2">
														<option value="" selected="selected"
															data-th-text="#{label.common.all}"></option>
													</select>
												</div>
											</div>
										</div>
									</div>
									<div class="row">
										<div class="col-sm-12">
											<div class="text-center">
												<button type="submit" class="btn btn-sm btn-primary" data-th-text="#{button.search}"></button>
												<button type="button" class="btn btn-sm btn-outline-primary" data-action-button="reset" data-th-text="#{button.reset}"></button>
											</div>
										</div>
									</div>
								</form>
							</div>
						</div>
					</div>
					<!-- /.col-lg-12 -->
				</div>
				<!-- /.row -->

				<div class="row">
					<div class="col-lg-12">
						<div class="card card-primary card-outline">
							<div class="card-header">
								<h3 class="card-title" data-th-text="#{title.list}"></h3>
								<div class="card-tools">
									<button type="button" class="btn btn-sm btn-success" data-action-button="order">[(#{button.order})]</button>
								</div>
							</div>
							<!-- /.card-header -->
							<div class="card-body">
								<table id="dataTable" class="table table-sm table-bordered table-hover table-striped">
									<thead>
										<tr>
											<th data-th-text="#{label.code.domainId}"></th>
											<th data-th-text="#{label.code.value}"></th>
											<th data-th-text="#{label.code.description}"></th>
											<th data-th-text="#{label.code.domainSeq}"></th>
										</tr>
									</thead>
								</table>
							</div>
							<!-- /.card-body -->
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>

	<th:block layout:fragment="script">
		<script>
			$(function() {
				var form = $("#search-form");
				var validator = form.validate();
				var selectedRowData;
				
				$("#SEQ").val("");
				
				// 공통코드 콤보박스 생성
				$('select[name="DOMAINID"]').createSelectBox({
					url : _ctx + "/api/code/group"
				});

				// 조회결과 테이블 생성
				var dataTable = $('#dataTable').createDataTable({
						url: _ctx + "/api/code/common/code/dataList",
						bPaginate: false,
						dom : '<"float-right"i>frt',
						params: {},
						columns: [
							{data : "DOMAINID"},
							{data : "CODE_ID"},
							{data : "CODE_NM"},
							{data : "DOMAIN_SEQ"}
						],
						columnDefs: [
							{
								targets: [0],
								className: 'text-center',
								render: function ( data, type, full ) {
									return '<span>'+data+'</span><input type="hidden" name="DOMAIN_ID" value="'+full['DOMAINID']+'">';
								}
							},
							{
								targets: [1],
								className: 'text-center',
								render: function ( data, type, full ) {
									return '<span>'+data+'</span><input type="hidden" name="CODE_ID" value="'+full['CODE_ID']+'">';
								}
							},							
							{
								targets: [2],
								className: 'text-center'
							},
							{
								targets: [3],
								className: 'text-center'
							}
						],
						callback : function(){
							$('#dataTable tbody').sortable({
								placeholder : "bg-warning"
							}); 
						}
				});
				
				// 폼 전송 이벤트
				form.submit(function(e) {
				    e.preventDefault();
				    if($('[name="DOMAINID"]').val() == '') {
				    	alert("도메인 ID를 선택해주세요.");
				    	return false;
				    }
				    $.fn.executeAction('search');
				});
				
				// 프로세스 처리 함수
				$.fn.executeAction = function(procType) {
					switch(procType) {
						case 'reset' :		// 조회조건 초기화
							form[0].reset();
							form.find("select").trigger("change");
							break;
						case 'search' :
							var dataTableParams = form.serialize();
							$("#SEQ").val(1);
					    	dataTable.ajax.url(_ctx + '/api/code/common/code/dataList?' + dataTableParams).draw();
							break;
						case 'order' :
							if($('select[name="DOMAINID"]').val() == "" || $('#SEQ').val() != 1){
								
									alert("조회 후 변경 가능합니다.");
									return;
							}
							
							var dataArrayBaseId = [];
							var dataArrayOrderNo = [];
							
							$('#dataTable [name="CODE_ID"]').each(function(idx, element) {
									console.log(idx + ' : ' + $(this).val());
									dataArrayOrderNo.push($(this).val());
							});
							
							// 폼 데이터 전송
							$.sendData({
								url: '/api/code/common/code/updateOrderNo',
								data: dataArrayOrderNo,
								notification: true,
								isIframe: true
							}, function(data) {
								if(data.result == 'S') {
									var dataTableParams = form.serialize();
									$("#SEQ").val(1);
							    	dataTable.ajax.url(_ctx + '/api/code/common/code/dataList?' + dataTableParams).draw();
								}
							});
							
							break;
						default :
							;
					}
				}
				
				// 버튼 이벤트
				$('[data-action-button]').on('click', function() {
					$(this).executeAction($(this).data('action-button'));
				});
				
			});
		</script>
	</th:block>
</body>
</html>