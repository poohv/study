<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.kyobo.mapper.maximo.attach.AttachMapper">
	<sql id="search_query">
		SELECT ATTACH.*
		FROM (
			SELECT A.ATTACH_ID
				, ORDER_NO
				, FILE_NAME
				, ORG_FILE_NAME
				, EXTENSION
				, PATH
				, (SIZE / 1024) AS SIZE
				, A.REG_USER_ID
				, VARCHAR_FORMAT(A.REG_DT, 'YYYY/MM/DD') AS REG_DT
			FROM TB_ATTACH A, TB_ATTACH_DETAIL B
			WHERE A.ATTACH_ID = B.ATTACH_ID
		) ATTACH
	</sql>
	<sql id="search_conditions">
		WHERE ATTACH_ID = #{ATTACH_ID}
		<if test="ORDER_NO != null and ORDER_NO != ''">
			AND ORDER_NO = #{ORDER_NO}
		</if>
		ORDER BY ORDER_NO
	</sql>
	<select id="findAll" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
			<if test="length!=null and !length.equals('') and length > -1">
				LIMIT ${length}
				OFFSET ${start}
			</if>
		) A
	</select>
	
	<select id="findCount" parameterType="HashMap" resultType="int">
		SELECT count(*)
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<select id="findOne" parameterType="HashMap" resultType="HashMap">
		SELECT *
		FROM (
			<include refid="search_query"></include>
			<include refid="search_conditions"></include>
		) A
	</select>
	
	<insert id="insert" parameterType="HashMap">
		<selectKey resultType="string" keyProperty="ATTACH_ID" order="BEFORE">
			SELECT COALESCE(
				(SELECT SUBSTRING(MAX(ATTACH_ID), 1, 6) || LPAD(CAST(SUBSTRING(MAX(ATTACH_ID), 7, 4) AS INT) + 1, 4, '0')
				FROM TB_ATTACH
				WHERE SUBSTRING(ATTACH_ID, 1, 6) = VARCHAR_FORMAT(CURRENT TIMESTAMP, 'YYYYMM'))
				, VARCHAR_FORMAT(CURRENT TIMESTAMP, 'YYYYMM') || '0001')
			FROM "SYSIBM".SYSDUMMY1
		</selectKey>
		INSERT INTO TB_ATTACH (
			TB_ATTACHID
			, ATTACH_ID
			, REG_USER_ID
			, REG_DT
		) VALUES (
		 	NEXTVAL FOR TB_ATTACHIDSEQ
			, #{ATTACH_ID}
			, #{REG_USER_ID}
			, CURRENT TIMESTAMP
		)
	</insert>
	
	<insert id="insertDetail" parameterType="HashMap">
		INSERT INTO TB_ATTACH_DETAIL (
			TB_ATTACH_DETAILID
			, ATTACH_ID
			, ORDER_NO
			, FILE_NAME
			, ORG_FILE_NAME
			, EXTENSION
			, PATH
			, SIZE
			, REG_USER_ID
			, REG_DT
		) VALUES 
		<foreach collection="detailList" item="detail" separator=",">
			(
				NEXTVAL FOR TB_ATTACH_DETAILIDSEQ
				, #{ATTACH_ID}
				, #{detail.ORDER_NO}
				, #{detail.FILE_NAME}
				, #{detail.ORG_FILE_NAME}
				, #{detail.EXTENSION}
				, #{detail.PATH}
				, #{detail.SIZE}
				, #{REG_USER_ID}
				, CURRENT TIMESTAMP
			)
		</foreach>
	</insert>
	
	<delete id="delete" parameterType="HashMap">
		DELETE TB_ATTACH
		WHERE ATTACH_ID = #{ATTACH_ID}
	</delete>
	
	<delete id="deleteDetail" parameterType="HashMap">
		DELETE TB_ATTACH_DETAIL
		WHERE ATTACH_ID = #{ATTACH_ID}
	</delete>
</mapper>